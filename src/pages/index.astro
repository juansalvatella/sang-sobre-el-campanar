.comp-chip { padding: .15rem .5rem; border-radius: 99px; font-size: .73rem; border: 1px solid; }
.townsfolk-chip { border-color: #6a9be8; color: #6a9be8; }
.outsider-chip  { border-color: #4ab878; color: #4ab878; }
.minion-chip    { border-color: #e05888; color: #e05888; }
.demon-chip     { border-color: #e04848; color: #e04848; }
