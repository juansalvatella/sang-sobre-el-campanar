---
import { charNamesCa } from '../data/char-names-ca';
import { charAbilitiesCa } from '../data/char-abilities-ca';
const charNamesCaJson     = JSON.stringify(charNamesCa);
const charAbilitiesCaJson = JSON.stringify(charAbilitiesCa);
---

<!DOCTYPE html>
<html lang="ca">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Personatges de la partida — Sang sobre el Campanar</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://www.pocketgrimoire.co.uk" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #0f0808;
      color: #d4c4a0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 15px;
      padding: 1rem;
      min-height: 100vh;
    }
    .header {
      text-align: center;
      padding: 1.25rem 1rem 1rem;
      border-bottom: 1px solid rgba(196,136,42,.25);
      margin-bottom: 1.25rem;
    }
    .header h1 {
      font-size: 1.2rem;
      color: #c4882a;
      font-weight: 700;
      letter-spacing: .03em;
    }
    .header p {
      font-size: .8rem;
      color: #7a6a50;
      margin-top: .25rem;
    }
    .team-section { margin-bottom: 1.25rem; }
    .team-label {
      font-size: .7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      padding: .25rem .6rem;
      border-radius: 99px;
      border: 1px solid;
      display: inline-flex;
      margin-bottom: .6rem;
    }
    .team-townsfolk .team-label { color: #6a9be8; border-color: #6a9be8; background: rgba(58,106,170,.12); }
    .team-outsider  .team-label { color: #4ab878; border-color: #4ab878; background: rgba(58,138,90,.12); }
    .team-minion    .team-label { color: #e05888; border-color: #e05888; background: rgba(170,58,90,.12); }
    .team-demon     .team-label { color: #e04848; border-color: #e04848; background: rgba(180,40,40,.15); }
    .team-traveller .team-label { color: #d4a030; border-color: #d4a030; background: rgba(138,106,32,.12); }
    .team-fabled    .team-label { color: #a870e8; border-color: #a870e8; background: rgba(106,58,170,.12); }
    .char-list { display: flex; flex-direction: column; gap: .5rem; }
    .char-row {
      display: flex; align-items: center; gap: .75rem;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 10px;
      padding: .55rem .75rem;
    }
    .char-token {
      width: 46px; height: 46px; flex-shrink: 0;
      border-radius: 50%;
      border: 2px solid;
      overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem; font-weight: bold;
    }
    .team-townsfolk .char-token { border-color: #6a9be8; background: rgba(58,106,170,.15); color: #6a9be8; }
    .team-outsider  .char-token { border-color: #4ab878; background: rgba(58,138,90,.15); color: #4ab878; }
    .team-minion    .char-token { border-color: #e05888; background: rgba(170,58,90,.15); color: #e05888; }
    .team-demon     .char-token { border-color: #e04848; background: rgba(180,40,40,.2);  color: #e04848; }
    .team-traveller .char-token { border-color: #d4a030; background: rgba(138,106,32,.15); color: #d4a030; }
    .team-fabled    .char-token { border-color: #a870e8; background: rgba(106,58,170,.15); color: #a870e8; }
    .char-token img { width: 100%; height: 100%; object-fit: cover; }
    .char-info { flex: 1; min-width: 0; }
    .char-name {
      font-size: .9rem;
      font-weight: 600;
      color: #e0d4b0;
      margin-bottom: .18rem;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: .25rem;
    }
    .char-name[href] { color: #e8c16a; }
    .char-name[href]::after {
      content: "↗";
      font-size: .68rem;
      color: #8b6a32;
    }
    .char-name[href]:hover {
      color: #ffd989;
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .char-ability { font-size: .75rem; color: #7a6a50; font-style: italic; line-height: 1.4; }
    .empty {
      text-align: center; padding: 3rem 1rem;
      color: #7a6a50; font-size: .9rem;
    }
    .footer {
      text-align: center; padding: 1.5rem 1rem;
      font-size: .72rem; color: #4a3a28;
      border-top: 1px solid rgba(196,136,42,.15);
      margin-top: 2rem;
    }
  </style>
</head>
<body>

<div class="header">
  <h1>🎩 Personatges disponibles</h1>
  <p id="subtitle">Carregant...</p>
</div>

<div id="content"></div>

<div class="footer">Sang sobre el Campanar — Blood on the Clocktower</div>

<script id="char-names-ca-data"     type="application/json" set:html={charNamesCaJson}></script>
<script id="char-abilities-ca-data" type="application/json" set:html={charAbilitiesCaJson}></script>

<script is:inline>
(async function () {
  const CDN        = 'https://www.pocketgrimoire.co.uk';
  const WIKI_BASE  = 'https://wiki.bloodontheclocktower.com/';
  const NAMES_CA   = JSON.parse(document.getElementById('char-names-ca-data').textContent);
  const ABILITIES_CA = JSON.parse(document.getElementById('char-abilities-ca-data').textContent);
  function getNameCa(id, n)    { return NAMES_CA[id]     ?? n; }
  function getAbilityCa(id, a) { return ABILITIES_CA[id] ?? a; }
  function escapeHtml(value = '') {
    return String(value).replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
  }
  function wikiUrl(nameEn) {
    return WIKI_BASE + encodeURIComponent(nameEn.replace(/\s+/g, '_')).replace(/%27/g, "'");
  }

  const TEAM_LABELS = {
    townsfolk:'Vilatans', outsider:'Forasters', minion:'Esbirros',
    demon:'Dimonis', traveller:'Viatgers', fabled:'Llegendes',
  };
  const TEAM_ORDER = ['townsfolk','outsider','minion','demon','traveller','fabled'];

  const params = new URLSearchParams(location.search);
  const ids    = (params.get('chars')||'').split(',').map(s=>s.trim()).filter(Boolean);

  const content  = document.getElementById('content');
  const subtitle = document.getElementById('subtitle');

  if (!ids.length) {
    subtitle.textContent = 'Cap personatge especificat';
    content.innerHTML = '<div class="empty">🎩<br>Aquest enllaç no té cap llista de personatges.</div>';
    return;
  }

  let allChars = [];
  try {
    const res = await fetch('/data/characters.json');
    allChars  = await res.json();
  } catch(_) {}

  const chars = ids.map(id => allChars.find(c=>c.id===id)).filter(Boolean);
  subtitle.textContent = `${chars.length} personatge${chars.length!==1?'s':''} en joc`;

  const byTeam = {};
  chars.forEach(c => { (byTeam[c.team]||(byTeam[c.team]=[])).push(c); });

  const html = TEAM_ORDER.filter(t=>byTeam[t]?.length).map(team => `
    <div class="team-section team-${team}">
      <div class="team-label">${TEAM_LABELS[team]||team}</div>
      <div class="char-list">${byTeam[team].map(c => {
        const url  = `${CDN}/build/img/roles/${c.id}_g.webp`;
        const name = getNameCa(c.id, c.name);
        const ab   = getAbilityCa(c.id, c.ability||'');
        const nameHtml = c.id?.startsWith('custom_')
          ? `<span class="char-name">${escapeHtml(name)}</span>`
          : `<a class="char-name" href="${wikiUrl(c.name)}" target="_blank" rel="noopener">${escapeHtml(name)}</a>`;
        return `<div class="char-row">
          <div class="char-token">
            <img src="${url}" alt="${escapeHtml(name)}" onerror="this.parentNode.textContent='${escapeHtml(name[0] || '?')}'" loading="lazy"/>
          </div>
          <div class="char-info">
            ${nameHtml}
            ${ab ? `<div class="char-ability">${escapeHtml(ab)}</div>` : ''}
          </div>
        </div>`;
      }).join('')}</div>
    </div>
  `).join('');

  content.innerHTML = html || '<div class="empty">Cap personatge.</div>';
})();
</script>

</body>
</html>
