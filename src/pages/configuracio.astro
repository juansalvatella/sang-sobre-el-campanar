---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Configuració" activePage="configuracio">
  <div class="config-page container">

    <div class="page-header">
      <h1 class="page-title">⚙️ Configuració</h1>
      <p class="page-subtitle">Gestiona els personatges homebrew de Paisings</p>
    </div>

    <div class="config-section">
      <div class="config-section-header">
        <div>
          <h2 class="config-section-title">🐉 Personatges Paisings</h2>
          <p class="config-section-desc">Els teus personatges personalitzats apareixeran al selector del Barret Seleccionador.</p>
        </div>
        <button class="btn btn-primary" id="btn-new-char">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
          Nou Personatge
        </button>
      </div>

      <div id="chars-empty" class="chars-empty" style="display:none">
        <span style="font-size:2.5rem">🐉</span>
        <p>Cap personatge Paisings encara.</p>
        <p style="font-size:.85rem;color:var(--text-dim);margin-top:.25rem">Crea el primer personatge per afegir-lo al teu univers.</p>
      </div>

      <div id="chars-list" class="chars-list"></div>
    </div>

  </div>

  <!-- Create / Edit character modal -->
  <div id="char-modal" class="modal-overlay" style="display:none">
    <div class="modal" style="max-width:480px">
      <div class="modal-header">
        <h3 id="modal-title">✏️ Nou Personatge Paisings</h3>
        <button class="modal-close btn" id="close-modal">✕</button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="edit-id" value="" />
        <div class="form-group">
          <label class="form-label">Nom del personatge *</label>
          <input type="text" id="cc-name" class="input" placeholder="Ex: El Mag Fosc" />
        </div>
        <div class="form-group">
          <label class="form-label">Descripció del poder</label>
          <textarea id="cc-ability" class="input" rows="3" placeholder="Ex: Cada nit, aprens si el teu veí és bo o dolent." style="resize:vertical"></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Alineació</label>
            <div class="radio-group">
              <label class="radio-label"><input type="radio" name="cc-align" value="good" checked /> Bo</label>
              <label class="radio-label"><input type="radio" name="cc-align" value="evil" /> Dolent</label>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Filiació</label>
            <select id="cc-team" class="input">
              <option value="townsfolk">Vilatà</option>
              <option value="outsider">Foraster</option>
              <option value="minion">Esbirro</option>
              <option value="demon">Dimoni</option>
              <option value="traveller">Viatger</option>
            </select>
          </div>
        </div>
        <div id="cc-error" class="form-error" style="display:none"></div>
        <div style="display:flex;justify-content:flex-end;gap:.75rem;margin-top:1rem">
          <button class="btn btn-ghost" id="cancel-modal">Cancel·lar</button>
          <button class="btn btn-primary" id="save-modal">Desar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete confirm modal -->
  <div id="delete-modal" class="modal-overlay" style="display:none">
    <div class="modal" style="max-width:380px">
      <div class="modal-header">
        <h3>Eliminar personatge</h3>
        <button class="modal-close btn" id="close-delete">✕</button>
      </div>
      <div class="modal-body">
        <p style="margin-bottom:1rem">Segur que vols eliminar <strong id="delete-name"></strong>? Desapareixerà del Barret i de totes les partides desades.</p>
        <div style="display:flex;justify-content:flex-end;gap:.75rem">
          <button class="btn btn-ghost" id="cancel-delete">Cancel·lar</button>
          <button class="btn btn-danger" id="confirm-delete">Eliminar</button>
        </div>
      </div>
    </div>
  </div>

</Layout>

<script is:inline>
(function () {
  const CDN = 'https://www.pocketgrimoire.co.uk';
  const TEAM_LABELS = {
    townsfolk:'Vilatà', outsider:'Foraster', minion:'Esbirro',
    demon:'Dimoni', traveller:'Viatger', fabled:'Llegenda',
  };

  function loadChars() {
    try { return JSON.parse(localStorage.getItem('botc_custom_chars') || '[]'); } catch(_) { return []; }
  }

  function saveChars(chars) {
    localStorage.setItem('botc_custom_chars', JSON.stringify(chars));
  }

  function imgUrl(id) {
    if (!id || id.startsWith('custom_')) return null;
    return `${CDN}/build/img/roles/${id}_g.webp`;
  }

  function render() {
    const chars = loadChars();
    const empty = document.getElementById('chars-empty');
    const list  = document.getElementById('chars-list');
    if (!chars.length) {
      empty.style.display = '';
      list.innerHTML = '';
      return;
    }
    empty.style.display = 'none';
    list.innerHTML = chars.map(c => {
      const teamLabel = TEAM_LABELS[c.team] || c.team;
      const initial = (c.name||'?')[0].toUpperCase();
      return `
        <div class="char-row team-${c.team}" data-id="${c.id}">
          <div class="char-token team-${c.team}">
            <span class="char-initial">${initial}</span>
          </div>
          <div class="char-info">
            <div class="char-name">${c.name}</div>
            <div class="char-badges">
              <span class="badge team-${c.team}">${teamLabel}</span>
              <span class="paisings-tag">🐉 Paisings</span>
            </div>
            <div class="char-ability">${c.ability ? `"${c.ability}"` : '<em style="color:var(--text-dim)">Sense descripció</em>'}</div>
          </div>
          <div class="char-actions">
            <button class="btn btn-ghost btn-sm btn-edit" data-id="${c.id}" title="Editar">✏️</button>
            <button class="btn btn-danger btn-sm btn-delete" data-id="${c.id}" data-name="${c.name}" title="Eliminar">🗑</button>
          </div>
        </div>
      `;
    }).join('');

    list.querySelectorAll('.btn-edit').forEach(btn => {
      btn.addEventListener('click', () => openEdit(btn.dataset.id));
    });
    list.querySelectorAll('.btn-delete').forEach(btn => {
      btn.addEventListener('click', () => openDelete(btn.dataset.id, btn.dataset.name));
    });
  }

  // ── Create / Edit modal ──────────────────────────────────────
  let editingId = null;

  function openCreate() {
    editingId = null;
    document.getElementById('modal-title').textContent = '✏️ Nou Personatge Paisings';
    document.getElementById('edit-id').value = '';
    document.getElementById('cc-name').value = '';
    document.getElementById('cc-ability').value = '';
    document.getElementById('cc-team').value = 'townsfolk';
    document.querySelector('[name="cc-align"][value="good"]').checked = true;
    document.getElementById('cc-error').style.display = 'none';
    document.getElementById('save-modal').textContent = 'Crear';
    document.getElementById('char-modal').style.display = '';
    document.getElementById('cc-name').focus();
  }

  function openEdit(id) {
    const chars = loadChars();
    const c = chars.find(x => x.id === id);
    if (!c) return;
    editingId = id;
    document.getElementById('modal-title').textContent = '✏️ Editar Personatge';
    document.getElementById('edit-id').value = id;
    document.getElementById('cc-name').value = c.name;
    document.getElementById('cc-ability').value = c.ability || '';
    document.getElementById('cc-team').value = c.team || 'townsfolk';
    const align = document.querySelector(`[name="cc-align"][value="${c.alignment||'good'}"]`);
    if (align) align.checked = true;
    document.getElementById('cc-error').style.display = 'none';
    document.getElementById('save-modal').textContent = 'Desar canvis';
    document.getElementById('char-modal').style.display = '';
    document.getElementById('cc-name').focus();
  }

  function closeModal() { document.getElementById('char-modal').style.display = 'none'; editingId = null; }

  document.getElementById('btn-new-char').addEventListener('click', openCreate);
  document.getElementById('close-modal').addEventListener('click', closeModal);
  document.getElementById('cancel-modal').addEventListener('click', closeModal);
  document.getElementById('char-modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });

  document.getElementById('save-modal').addEventListener('click', () => {
    const name = document.getElementById('cc-name').value.trim();
    if (!name) {
      document.getElementById('cc-error').textContent = 'El nom és obligatori.';
      document.getElementById('cc-error').style.display = '';
      return;
    }
    const chars = loadChars();
    if (editingId) {
      const idx = chars.findIndex(c => c.id === editingId);
      if (idx >= 0) {
        chars[idx] = { ...chars[idx], name, ability: document.getElementById('cc-ability').value.trim(), team: document.getElementById('cc-team').value, alignment: document.querySelector('[name="cc-align"]:checked')?.value || 'good' };
      }
    } else {
      chars.push({
        id: `custom_${Date.now()}`,
        name,
        ability: document.getElementById('cc-ability').value.trim(),
        team: document.getElementById('cc-team').value,
        alignment: document.querySelector('[name="cc-align"]:checked')?.value || 'good',
        edition: 'custom', firstNight: 0, firstNightReminder: '', otherNight: 0, otherNightReminder: '', reminders: [], setup: false,
      });
    }
    saveChars(chars);
    closeModal();
    render();
  });

  // ── Delete modal ─────────────────────────────────────────────
  let deletingId = null;

  function openDelete(id, name) {
    deletingId = id;
    document.getElementById('delete-name').textContent = name;
    document.getElementById('delete-modal').style.display = '';
  }

  function closeDelete() { document.getElementById('delete-modal').style.display = 'none'; deletingId = null; }

  document.getElementById('close-delete').addEventListener('click', closeDelete);
  document.getElementById('cancel-delete').addEventListener('click', closeDelete);
  document.getElementById('delete-modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeDelete(); });

  document.getElementById('confirm-delete').addEventListener('click', () => {
    if (!deletingId) return;
    let chars = loadChars().filter(c => c.id !== deletingId);
    saveChars(chars);
    // Remove from hat too
    try {
      const hat = JSON.parse(localStorage.getItem('botc_hat') || '{}');
      if (hat.hat) { hat.hat = hat.hat.filter(c => c.id !== deletingId); localStorage.setItem('botc_hat', JSON.stringify(hat)); }
    } catch(_) {}
    closeDelete();
    render();
  });

  render();
})();
</script>

<style is:global>
.config-page { padding: 0 1rem 4rem; max-width: 900px; }

.config-section {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}

.config-section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--border);
  background: rgba(196,136,42,.03);
}

.config-section-title {
  font-family: var(--font-serif);
  font-size: 1.15rem;
  color: var(--accent);
  margin-bottom: .25rem;
}

.config-section-desc {
  font-size: .8rem;
  color: var(--text-dim);
}

.chars-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: .5rem;
  padding: 4rem 2rem;
  color: var(--text-muted);
  font-size: .9rem;
}

.chars-list { padding: .5rem 0; }

.char-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: .75rem 1.5rem;
  border-bottom: 1px solid var(--border);
  transition: background .1s;
}
.char-row:last-child { border-bottom: none; }
.char-row:hover { background: var(--bg-hover); }

.char-token {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 2px solid var(--team-color, var(--border-accent));
  background: var(--team-bg, rgba(196,136,42,.1));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.char-initial {
  font-size: 1.2rem;
  font-weight: bold;
  color: var(--team-color, var(--text-muted));
}

.char-info { flex: 1; min-width: 0; }

.char-name {
  font-size: .95rem;
  font-weight: 600;
  font-family: var(--font-serif);
  color: var(--text);
  margin-bottom: .3rem;
}

.char-badges {
  display: flex;
  gap: .3rem;
  align-items: center;
  margin-bottom: .35rem;
  flex-wrap: wrap;
}

/* Team badge brighter colors (same as biblioteca) */
.char-row.team-townsfolk .badge { color: #6a9be8; border-color: #6a9be8; background: rgba(58,106,170,.18); }
.char-row.team-outsider  .badge { color: #4ab878; border-color: #4ab878; background: rgba(58,138,90,.18); }
.char-row.team-minion    .badge { color: #e05888; border-color: #e05888; background: rgba(170,58,90,.18); }
.char-row.team-demon     .badge { color: #e04848; border-color: #e04848; background: rgba(180,40,40,.2); }
.char-row.team-traveller .badge { color: #d4a030; border-color: #d4a030; background: rgba(138,106,32,.18); }
.char-row.team-fabled    .badge { color: #a870e8; border-color: #a870e8; background: rgba(106,58,170,.18); }

.paisings-tag {
  font-size: .65rem;
  padding: .1rem .4rem;
  border-radius: 99px;
  background: rgba(106,58,170,.15);
  border: 1px solid #6a3aaa;
  color: #9a6ada;
  font-weight: 600;
}

.char-ability {
  font-size: .78rem;
  color: var(--text-muted);
  font-style: italic;
  line-height: 1.4;
}

.char-actions {
  display: flex;
  gap: .4rem;
  flex-shrink: 0;
}

.btn-sm {
  padding: .25rem .5rem;
  font-size: .75rem;
}

/* Reuse form styles from setup */
.form-group { margin-bottom: .85rem; }
.form-label { display: block; font-size: .8rem; color: var(--text-muted); margin-bottom: .3rem; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.form-error { color: var(--red-light); font-size: .8rem; margin-top: .25rem; }
.radio-group { display: flex; gap: 1rem; margin-top: .25rem; }
.radio-label { display: flex; align-items: center; gap: .4rem; font-size: .85rem; color: var(--text-muted); cursor: pointer; }

@media (max-width: 640px) {
  .config-section-header { flex-direction: column; }
  .form-row { grid-template-columns: 1fr; }
}
</style>
