---
import Layout from '../layouts/Layout.astro';
import { ca } from '../i18n/ca';
import { charNamesCa } from '../data/char-names-ca';
import { charAbilitiesCa } from '../data/char-abilities-ca';
const charNamesCaJson     = JSON.stringify(charNamesCa);
const charAbilitiesCaJson = JSON.stringify(charAbilitiesCa);
---

<Layout title={ca.grimoire.title} activePage="partida">
  <div class="grimoire-page">

    <aside class="sidebar">
      <div class="sidebar-section">
        <h3 class="sidebar-title">Partida</h3>
        <button class="sidebar-btn" id="sb-add-player">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
          Afegeix Jugador
        </button>
        <button class="sidebar-btn" id="sb-farols">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>
          Dimonis de Farol
        </button>
        <a class="sidebar-btn" href="/ordre-de-nit">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11.1 12.08c-2.33-4.51-.5-8.48.53-10.07C6.27 2.2 1.98 6.59 1.98 12c0 .14.02.28.02.42.62-.27 1.29-.42 2-.42 1.66 0 3.18.83 4.1 2.1A4.98 4.98 0 0 1 12 13c.08 0 .16.01.24.02C12.12 12.64 11.74 12.38 11.1 12.08z"/></svg>
          Ordre de Nit
        </a>
        <button class="sidebar-btn danger" id="sb-clear">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
          Nova Partida
        </button>
      </div>
      <div class="sidebar-section">
        <h3 class="sidebar-title">Jugadors</h3>
        <div id="player-list"></div>
      </div>
      <div class="sidebar-section">
        <h3 class="sidebar-title">Notes</h3>
        <textarea id="notes-area" class="notes-input" placeholder="Escriu les teves notes aquí..."></textarea>
      </div>
    </aside>

    <div class="grimoire-main">
      <div id="empty-state" class="empty-state" style="display:none">
        <div class="empty-state-icon">📖</div>
        <p>No hi ha cap partida activa.</p>
        <p style="font-size:.85rem;margin-top:.25rem">Afegeix jugadors o torna a la configuració.</p>
        <a href="/" class="btn btn-primary" style="margin-top:1.5rem;text-decoration:none">Anar a Configuració</a>
      </div>
      <div id="grimoire-circle" class="grimoire-circle"></div>
    </div>
  </div>

  <!-- Token action modal -->
  <div id="token-modal" class="modal-overlay" style="display:none">
    <div class="modal">
      <div class="modal-header">
        <div style="display:flex;align-items:center;gap:.75rem">
          <div id="modal-token-img" class="modal-token"></div>
          <div>
            <h3 id="modal-char-name"></h3>
            <div id="modal-char-team" class="badge" style="margin-top:.25rem"></div>
          </div>
        </div>
        <button class="modal-close btn" id="close-token-modal">✕</button>
      </div>
      <div class="modal-body">
        <p id="modal-char-ability" style="color:var(--text-muted);font-size:.85rem;margin-bottom:1rem;font-style:italic"></p>
        <div class="modal-actions">
          <button class="modal-action-btn" id="btn-toggle-dead"></button>
          <button class="modal-action-btn" id="btn-replace">Substituir</button>
          <button class="modal-action-btn" id="btn-add-reminder">Recordatori</button>
          <button class="modal-action-btn danger" id="btn-remove-player">Eliminar</button>
        </div>
        <div id="reminders-display" style="margin-top:1rem"></div>
      </div>
    </div>
  </div>

  <!-- Character picker -->
  <div id="char-picker-modal" class="modal-overlay" style="display:none">
    <div class="modal" style="max-width:680px">
      <div class="modal-header">
        <h3 id="picker-title">Selecciona Personatge</h3>
        <button class="modal-close btn" id="close-picker">✕</button>
      </div>
      <div class="modal-body">
        <input type="text" class="input" id="picker-search" placeholder="Cerca personatge..." style="margin-bottom:1rem" />
        <div id="char-picker-grid" class="char-picker-grid"></div>
      </div>
    </div>
  </div>

  <!-- Dimonis de farol modal -->
  <div id="farols-modal" class="modal-overlay" style="display:none">
    <div class="modal" style="max-width:680px">
      <div class="modal-header">
        <h3>🎭 Dimonis de Farol</h3>
        <button class="modal-close btn" id="close-farols">✕</button>
      </div>
      <div class="modal-body">
        <p style="color:var(--text-muted);font-size:.85rem;margin-bottom:1rem">Personatges que el Dimoni pot fer servir com a farol.</p>
        <div id="farol-active-display"></div>
        <hr class="divider"/>
        <p style="color:var(--text-dim);font-size:.78rem;margin-bottom:.5rem">Canviar manualment:</p>
        <div id="farols-grid" class="char-picker-grid"></div>
      </div>
    </div>
  </div>
</Layout>

<script id="char-names-ca-data"     type="application/json" set:html={charNamesCaJson}></script>
<script id="char-abilities-ca-data" type="application/json" set:html={charAbilitiesCaJson}></script>

<script is:inline>
(async function () {
  const CDN = 'https://www.pocketgrimoire.co.uk';
  const NAMES_CA     = JSON.parse(document.getElementById('char-names-ca-data').textContent);
  const ABILITIES_CA = JSON.parse(document.getElementById('char-abilities-ca-data').textContent);
  function getNameCa(id, nameEn)     { return NAMES_CA[id]     ?? nameEn; }
  function getAbilityCa(id, abilityEn) { return ABILITIES_CA[id] ?? abilityEn; }
  const TEAM_LABELS = {townsfolk:'Habitants',outsider:'Forasters',minion:'Servents',demon:'Dimonis',traveller:'Viatgers',fabled:'Llegendes'};

  let ALL_CHARS = [];
  try {
    const res = await fetch('/data/characters.json');
    ALL_CHARS = await res.json();
  } catch(e) { console.error('Error loading characters:', e); }

  let players = [], bluffs = [], notes = '', selectedSetupChars = [];
  let activeIdx = null, pickerMode = 'add';

  function loadState() {
    try {
      const setup = JSON.parse(localStorage.getItem('botc_setup')||'{}');
      selectedSetupChars = setup.chars || [];
      const game = JSON.parse(localStorage.getItem('botc_game')||'{}');
      players = game.players || [];
      bluffs  = game.bluffs  || [];
      notes   = game.notes   || '';
      const custom = JSON.parse(localStorage.getItem('botc_custom_chars')||'[]');
      custom.forEach(c => { if(!ALL_CHARS.find(x=>x.id===c.id)) ALL_CHARS.push(c); });
      // Restore custom chars for players
      players.forEach(p => {
        if (p.customChar && !ALL_CHARS.find(x=>x.id===p.charId)) ALL_CHARS.push(p.customChar);
      });
    } catch(_) {}
  }

  function saveGame() {
    localStorage.setItem('botc_game', JSON.stringify({players, bluffs, notes}));
  }

  function imgUrl(id) {
    if (!id || id.startsWith('custom_')) return null;
    return `${CDN}/build/img/roles/${id}_g.webp`;
  }

  function charById(id) { return ALL_CHARS.find(c=>c.id===id); }

  // Circle
  function renderCircle() {
    const circle = document.getElementById('grimoire-circle');
    const empty  = document.getElementById('empty-state');
    if (!circle) return;
    if (!players.length) { circle.style.display='none'; empty.style.display=''; renderPlayerList(); return; }
    circle.style.display=''; empty.style.display='none';
    circle.innerHTML = `<div class="tokens-ring">${players.map((p,i) => {
      const char = p.charId ? charById(p.charId) : null;
      const url = char ? imgUrl(char.id) : null;
      return `<div class="circle-token team-${char?.team||'townsfolk'} ${p.dead?'dead':''}" data-idx="${i}" style="position:absolute">
        ${url ? `<img src="${url}" alt="${char.name}" onerror="this.style.display='none'" loading="lazy"/>` : `<span class="token-placeholder">${i+1}</span>`}
        ${p.dead ? '<div class="dead-shroud">†</div>' : ''}
        <div class="token-label">${p.name||`J${i+1}`}</div>
        ${char ? `<div class="token-char-name">${getNameCa(char.id, char.name)}</div>` : ''}
      </div>`;
    }).join('')}</div>`;
    circle.querySelectorAll('.circle-token').forEach(el => {
      el.addEventListener('click', () => openTokenModal(+el.dataset.idx));
    });
    positionTokens();
    renderPlayerList();
  }

  function positionTokens() {
    const ring = document.querySelector('.tokens-ring');
    if (!ring) return;
    const items = ring.querySelectorAll('.circle-token');
    const N = items.length; if (!N) return;
    const W = ring.offsetWidth||600, H = ring.offsetHeight||600;
    const cx=W/2, cy=H/2;
    const r = Math.min(cx,cy)*0.78;
    const tokenW = 80;
    items.forEach((el,i) => {
      const angle = (2*Math.PI*i/N) - Math.PI/2;
      el.style.left = `${cx + r*Math.cos(angle) - tokenW/2}px`;
      el.style.top  = `${cy + r*Math.sin(angle) - tokenW/2}px`;
    });
  }

  function renderPlayerList() {
    const list = document.getElementById('player-list');
    if (!list) return;
    if (!players.length) { list.innerHTML='<p style="color:var(--text-dim);font-size:.8rem">Cap jugador. Afegeix-ne un!</p>'; return; }
    list.innerHTML = players.map((p,i) => {
      const char = p.charId ? charById(p.charId) : null;
      const url = char ? imgUrl(char.id) : null;
      return `<div class="player-item ${p.dead?'dead':''}" data-idx="${i}">
        <div class="player-token-sm team-${char?.team||'townsfolk'}">
          ${url ? `<img src="${url}" alt="${char.name}" onerror="this.style.display='none'" loading="lazy"/>` : `<span>${i+1}</span>`}
        </div>
        <div class="player-info">
          <span class="player-name">${p.name||`Jugador ${i+1}`}</span>
          ${char ? `<span class="player-char">${getNameCa(char.id, char.name)}</span>` : ''}
        </div>
        ${p.dead ? '<span class="dead-badge">†</span>' : ''}
      </div>`;
    }).join('');
    list.querySelectorAll('.player-item').forEach(el => {
      el.addEventListener('click', () => openTokenModal(+el.dataset.idx));
    });
  }

  // Token modal
  function openTokenModal(idx) {
    activeIdx = idx;
    const p = players[idx];
    const char = p.charId ? charById(p.charId) : null;
    document.getElementById('modal-char-name').textContent = char ? getNameCa(char.id, char.name) : `Jugador ${idx+1}`;
    document.getElementById('modal-char-ability').textContent = char ? getAbilityCa(char.id, char.ability||'') : '';
    const teamEl = document.getElementById('modal-char-team');
    teamEl.textContent = char ? (TEAM_LABELS[char.team]||char.team) : '';
    teamEl.className = `badge team-${char?.team||'townsfolk'}`;
    document.getElementById('btn-toggle-dead').textContent = p.dead ? 'Revifar' : 'Emmortallar';
    const img = document.getElementById('modal-token-img');
    img.className = `modal-token team-${char?.team||'townsfolk'}`;
    const url = char ? imgUrl(char.id) : null;
    img.innerHTML = url ? `<img src="${url}" alt="${char.name}" onerror="this.style.display='none'" loading="lazy"/>` : `<span>${idx+1}</span>`;
    renderReminders(p);
    document.getElementById('token-modal').style.display = '';
  }

  function renderReminders(p) {
    const el = document.getElementById('reminders-display');
    if (!p.reminders?.length) { el.innerHTML=''; return; }
    el.innerHTML = `<p style="color:var(--text-muted);font-size:.8rem;margin-bottom:.5rem">Recordatoris:</p>
      <div style="display:flex;flex-wrap:wrap;gap:.5rem">
        ${p.reminders.map((r,ri) => `<span class="reminder-tag" data-ri="${ri}">${r} ✕</span>`).join('')}
      </div>`;
    el.querySelectorAll('.reminder-tag').forEach(tag => {
      tag.addEventListener('click', () => {
        players[activeIdx].reminders.splice(+tag.dataset.ri, 1);
        saveGame(); renderReminders(players[activeIdx]); renderCircle();
      });
    });
  }

  document.getElementById('close-token-modal').addEventListener('click', () => { document.getElementById('token-modal').style.display='none'; activeIdx=null; });
  document.getElementById('token-modal').addEventListener('click', e => { if(e.target===e.currentTarget){e.currentTarget.style.display='none'; activeIdx=null;} });

  document.getElementById('btn-toggle-dead').addEventListener('click', () => {
    if (activeIdx===null) return;
    players[activeIdx].dead = !players[activeIdx].dead;
    document.getElementById('btn-toggle-dead').textContent = players[activeIdx].dead ? 'Revifar' : 'Emmortallar';
    saveGame(); renderCircle();
  });

  document.getElementById('btn-remove-player').addEventListener('click', () => {
    if (activeIdx===null) return;
    players.splice(activeIdx,1);
    saveGame(); document.getElementById('token-modal').style.display='none'; activeIdx=null; renderCircle();
  });

  document.getElementById('btn-add-reminder').addEventListener('click', () => {
    if (activeIdx===null) return;
    const char = players[activeIdx].charId ? charById(players[activeIdx].charId) : null;
    const reminders = char?.reminders || [];
    let chosen;
    if (!reminders.length) { chosen = prompt('Recordatori personalitzat:'); }
    else {
      const opts = reminders.map((r,i)=>`${i+1}. ${r}`).join('\n');
      const n = prompt(`Selecciona:\n${opts}\n0. Personalitzat`);
      if (n===null) return;
      chosen = +n===0 ? prompt('Recordatori personalitzat:') : reminders[+n-1];
    }
    if (chosen?.trim()) { players[activeIdx].reminders.push(chosen.trim()); saveGame(); renderReminders(players[activeIdx]); renderCircle(); }
  });

  document.getElementById('btn-replace').addEventListener('click', () => {
    pickerMode='replace';
    document.getElementById('picker-title').textContent='Substituir Personatge';
    document.getElementById('picker-search').value='';
    renderPickerGrid('');
    document.getElementById('char-picker-modal').style.display='';
    document.getElementById('token-modal').style.display='none';
  });

  // Character picker
  document.getElementById('sb-add-player').addEventListener('click', () => {
    pickerMode='add';
    document.getElementById('picker-title').textContent='Afegeix Jugador';
    document.getElementById('picker-search').value='';
    renderPickerGrid('');
    document.getElementById('char-picker-modal').style.display='';
  });
  document.getElementById('close-picker').addEventListener('click', () => { document.getElementById('char-picker-modal').style.display='none'; });
  document.getElementById('char-picker-modal').addEventListener('click', e => { if(e.target===e.currentTarget) e.currentTarget.style.display='none'; });
  document.getElementById('picker-search').addEventListener('input', e => renderPickerGrid(e.target.value.toLowerCase()));

  function renderPickerGrid(q) {
    const inUse = new Set(players.map(p=>p.charId).filter(Boolean));
    let chars = selectedSetupChars.length ? ALL_CHARS.filter(c=>selectedSetupChars.includes(c.id)) : ALL_CHARS.filter(c=>['tb','bmr','snv'].includes(c.edition)||c.id.startsWith('custom_'));
    if (q) chars = chars.filter(c=>c.name.toLowerCase().includes(q) || getNameCa(c.id, c.name).toLowerCase().includes(q));
    const grid = document.getElementById('char-picker-grid');
    if (!chars.length) { grid.innerHTML='<p style="color:var(--text-muted);text-align:center;padding:2rem">Cap resultat.</p>'; return; }
    grid.innerHTML = chars.map(c => {
      const url = imgUrl(c.id);
      return `<button class="picker-char ${inUse.has(c.id)?'in-use':''} team-${c.team}" data-id="${c.id}" title="${c.ability||''}">
        <div class="picker-img team-${c.team}">${url?`<img src="${url}" alt="${c.name}" onerror="this.style.display='none'" loading="lazy"/>`:`<span>${getNameCa(c.id, c.name)[0]}</span>`}</div>
        <span>${getNameCa(c.id, c.name)}</span>
        ${inUse.has(c.id)?'<span class="in-use-badge">·</span>':''}
      </button>`;
    }).join('');
    grid.querySelectorAll('.picker-char').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id;
        if (pickerMode==='add') {
          const name = prompt(`Nom del jugador ${players.length+1} (opcional):`);
          players.push({id:Date.now(), name:name?.trim()||`Jugador ${players.length+1}`, charId:id, dead:false, reminders:[]});
        } else if (pickerMode==='replace' && activeIdx!==null) {
          players[activeIdx].charId = id;
        }
        saveGame(); document.getElementById('char-picker-modal').style.display='none'; renderCircle();
      });
    });
  }

  // Dimonis de farol
  document.getElementById('sb-farols').addEventListener('click', () => {
    renderFarolsModal();
    document.getElementById('farols-modal').style.display='';
  });
  document.getElementById('close-farols').addEventListener('click', () => { document.getElementById('farols-modal').style.display='none'; });
  document.getElementById('farols-modal').addEventListener('click', e => { if(e.target===e.currentTarget) e.currentTarget.style.display='none'; });

  function renderFarolsModal() {
    const activeEl = document.getElementById('farol-active-display');
    if (bluffs.length) {
      const farolChars = bluffs.map(id=>charById(id)).filter(Boolean);
      activeEl.innerHTML = `<div style="display:flex;flex-wrap:wrap;gap:.75rem;margin-bottom:.5rem">${farolChars.map(c => {
        const url = imgUrl(c.id);
        return `<div style="display:flex;flex-direction:column;align-items:center;gap:.3rem">
          <div class="picker-img team-${c.team}" style="width:52px;height:52px">${url?`<img src="${url}" alt="${c.name}" onerror="this.style.display='none'" loading="lazy"/>`:`<span>${getNameCa(c.id, c.name)[0]}</span>`}</div>
          <span style="font-size:.7rem;color:var(--accent)">${getNameCa(c.id, c.name)}</span>
        </div>`;
      }).join('')}</div>`;
    } else {
      activeEl.innerHTML = '<p style="color:var(--text-dim);font-size:.82rem;margin-bottom:.5rem">Cap farol actiu. Randomitza des de la configuració o tria manualment.</p>';
    }
    const inUse = new Set(players.map(p=>p.charId).filter(Boolean));
    let chars = selectedSetupChars.length ? ALL_CHARS.filter(c=>selectedSetupChars.includes(c.id)) : ALL_CHARS.filter(c=>['tb','bmr','snv'].includes(c.edition)||c.id.startsWith('custom_'));
    chars = chars.filter(c=>!inUse.has(c.id));
    const grid = document.getElementById('farols-grid');
    grid.innerHTML = chars.map(c => {
      const url = imgUrl(c.id);
      return `<button class="picker-char ${bluffs.includes(c.id)?'bluff-selected':''} team-${c.team}" data-id="${c.id}" title="${c.ability||''}">
        <div class="picker-img team-${c.team}">${url?`<img src="${url}" alt="${c.name}" onerror="this.style.display='none'" loading="lazy"/>`:`<span>${getNameCa(c.id, c.name)[0]}</span>`}</div>
        <span>${getNameCa(c.id, c.name)}</span>
        ${bluffs.includes(c.id)?'<span class="bluff-badge">🎭</span>':''}
      </button>`;
    }).join('');
    grid.querySelectorAll('.picker-char').forEach(btn => {
      btn.addEventListener('click', () => {
        const id=btn.dataset.id, idx=bluffs.indexOf(id);
        if(idx>=0){bluffs.splice(idx,1);btn.classList.remove('bluff-selected');}
        else{bluffs.push(id);btn.classList.add('bluff-selected');}
        saveGame(); renderFarolsModal();
      });
    });
  }

  // Notes
  document.getElementById('notes-area').addEventListener('input', e => { notes=e.target.value; saveGame(); });

  // Clear
  document.getElementById('sb-clear').addEventListener('click', () => {
    if (!confirm('Segur que vols iniciar una nova partida?')) return;
    players=[]; bluffs=[]; notes='';
    saveGame(); document.getElementById('notes-area').value=''; renderCircle();
  });

  window.addEventListener('resize', positionTokens);

  // Init
  loadState();
  renderCircle();
  document.getElementById('notes-area').value = notes;
})();
</script>

<style is:global>
.grimoire-page { display:flex; height:calc(100vh - 53px); overflow:hidden; }
.sidebar { width:240px; flex-shrink:0; background:var(--bg-card); border-right:1px solid var(--border); overflow-y:auto; padding:1rem; display:flex; flex-direction:column; gap:.5rem; }
.sidebar-section { margin-bottom:1.25rem; }
.sidebar-title { font-size:.7rem; font-family:var(--font-sans); text-transform:uppercase; letter-spacing:.1em; color:var(--text-dim); margin-bottom:.5rem; }
.sidebar-btn { display:flex; align-items:center; gap:.5rem; width:100%; padding:.45rem .6rem; border-radius:6px; font-size:.82rem; color:var(--text-muted); background:transparent; border:1px solid transparent; cursor:pointer; transition:all .15s; text-align:left; margin-bottom:.25rem; text-decoration:none; }
.sidebar-btn:hover { color:var(--text); background:var(--bg-hover); border-color:var(--border); }
.sidebar-btn.danger { color:var(--red-light); }
.sidebar-btn.danger:hover { background:rgba(139,26,26,.15); border-color:var(--red); }
.player-list { display:flex; flex-direction:column; gap:.35rem; }
.player-item { display:flex; align-items:center; gap:.5rem; padding:.35rem .5rem; border-radius:6px; cursor:pointer; transition:background .1s; }
.player-item:hover { background:var(--bg-hover); }
.player-item.dead { opacity:.5; }
.player-token-sm { width:28px; height:28px; border-radius:50%; border:1.5px solid var(--team-color,var(--border-accent)); overflow:hidden; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:.65rem; color:var(--text-muted); background:var(--team-bg,rgba(196,136,42,.1)); }
.player-token-sm img { width:100%; height:100%; object-fit:cover; }
.player-info { display:flex; flex-direction:column; min-width:0; flex:1; }
.player-name { font-size:.8rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.player-char { font-size:.7rem; color:var(--text-muted); }
.dead-badge { color:var(--text-dim); font-size:.9rem; }
.notes-input { width:100%; min-height:100px; background:var(--bg); border:1px solid var(--border); border-radius:var(--radius); color:var(--text); font-size:.8rem; font-family:inherit; padding:.5rem; resize:vertical; }
.notes-input:focus { outline:none; border-color:var(--accent-dark); }
.notes-input::placeholder { color:var(--text-dim); }
.grimoire-main { flex:1; overflow:hidden; position:relative; display:flex; align-items:center; justify-content:center; }
.grimoire-circle { width:100%; height:100%; position:relative; }
.tokens-ring { width:100%; height:100%; position:relative; }
.circle-token { width:80px; height:80px; border-radius:50%; border:2px solid var(--team-color,var(--border-accent)); background:var(--team-bg,rgba(196,136,42,.1)); overflow:visible; cursor:pointer; transition:transform .2s,box-shadow .2s; display:flex; align-items:center; justify-content:center; }
.circle-token > img { width:100%; height:100%; object-fit:cover; border-radius:50%; }
.circle-token:hover { transform:scale(1.12); box-shadow:0 0 16px rgba(196,136,42,.5); z-index:10; }
.circle-token.dead { filter:grayscale(.8) brightness(.45); border-color:#3a2020; }
.dead-shroud { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:1.4rem; color:#c04040; pointer-events:none; z-index:2; text-shadow:0 0 6px rgba(0,0,0,.8); }
.token-placeholder { font-size:1.2rem; color:var(--text-muted); font-weight:bold; }
.token-label { position:absolute; bottom:calc(100% + 4px); left:50%; transform:translateX(-50%); font-size:.65rem; color:var(--text-muted); white-space:nowrap; background:rgba(10,5,5,.85); padding:1px 4px; border-radius:3px; pointer-events:none; }
.token-char-name { position:absolute; top:calc(100% + 4px); left:50%; transform:translateX(-50%); font-size:.62rem; color:var(--accent); white-space:nowrap; background:rgba(10,5,5,.85); padding:1px 4px; border-radius:3px; pointer-events:none; }
.modal-token { width:52px; height:52px; border-radius:50%; border:2px solid var(--team-color,var(--border-accent)); background:var(--team-bg,rgba(196,136,42,.1)); overflow:hidden; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:1.1rem; color:var(--text-muted); }
.modal-token img { width:100%; height:100%; object-fit:cover; }
.modal-actions { display:grid; grid-template-columns:1fr 1fr; gap:.5rem; }
.modal-action-btn { padding:.6rem .75rem; background:var(--bg-hover); border:1px solid var(--border); border-radius:var(--radius); color:var(--text-muted); font-size:.85rem; cursor:pointer; transition:all .15s; text-align:center; }
.modal-action-btn:hover { color:var(--accent); border-color:var(--border-accent); }
.modal-action-btn.danger { color:var(--red-light); }
.modal-action-btn.danger:hover { background:rgba(139,26,26,.2); border-color:var(--red); }
.reminder-tag { display:inline-block; padding:.2rem .5rem; background:rgba(196,136,42,.15); border:1px solid var(--border-accent); border-radius:4px; font-size:.75rem; color:var(--text-muted); cursor:pointer; }
.reminder-tag:hover { color:var(--red-light); }
.char-picker-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(78px,1fr)); gap:.5rem; max-height:400px; overflow-y:auto; }
.picker-char { display:flex; flex-direction:column; align-items:center; gap:.3rem; padding:.5rem .3rem; background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); cursor:pointer; transition:all .15s; font-size:.68rem; color:var(--text-muted); position:relative; }
.picker-char:hover { border-color:var(--accent); color:var(--text); }
.picker-char.in-use { opacity:.4; }
.picker-char.bluff-selected { border-color:var(--accent); background:rgba(196,136,42,.1); }
.picker-img { width:48px; height:48px; border-radius:50%; border:1.5px solid var(--team-color,var(--border-accent)); background:var(--team-bg,rgba(196,136,42,.1)); overflow:hidden; display:flex; align-items:center; justify-content:center; }
.picker-img img { width:100%; height:100%; object-fit:cover; }
.in-use-badge,.bluff-badge { position:absolute; top:2px; right:2px; font-size:.65rem; }
@media(max-width:640px){.sidebar{width:180px}}
</style>
