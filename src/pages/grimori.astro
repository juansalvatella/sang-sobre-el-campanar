---
import Layout from '../layouts/Layout.astro';
import { ca } from '../i18n/ca';
import { charNamesCa } from '../data/char-names-ca';
import { charAbilitiesCa } from '../data/char-abilities-ca';
const charNamesCaJson     = JSON.stringify(charNamesCa);
const charAbilitiesCaJson = JSON.stringify(charAbilitiesCa);
---

<Layout title={ca.grimoire.title} activePage="partida">
  <div class="grimoire-page">

    <aside class="sidebar">
      <div class="sidebar-section">
        <h3 class="sidebar-title">Partida</h3>
        <button class="sidebar-btn" id="sb-add-player">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
          Afegeix jugador
        </button>
        <button class="sidebar-btn" id="sb-farols">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>
          Dimonis de farol
        </button>
        <button class="sidebar-btn" id="sb-qr">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 11h8V3H3v8zm2-6h4v4H5V5zm8-2v8h8V3h-8zm6 6h-4V5h4v4zM3 21h8v-8H3v8zm2-6h4v4H5v-4zm13-2h-2v2h2v-2zm2 0h-2v2h2v-2zm0 2h-2v2h2v-2zm-2 2h-2v2h2v-2zm0 2h-2v2h2v-2zm2-2h-2v2h2v-2zm0-4h-2v2h2v-2z"/></svg>
          QR jugadors
        </button>
        <button class="sidebar-btn" id="sb-night-order">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11.1 12.08c-2.33-4.51-.5-8.48.53-10.07C6.27 2.2 1.98 6.59 1.98 12c0 .14.02.28.02.42.62-.27 1.29-.42 2-.42 1.66 0 3.18.83 4.1 2.1A4.98 4.98 0 0 1 12 13c.08 0 .16.01.24.02C12.12 12.64 11.74 12.38 11.1 12.08z"/></svg>
          Ordre de nit
        </button>
        <button class="sidebar-btn danger" id="sb-clear">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
          Nova partida
        </button>
      </div>
      <div class="sidebar-section">
        <h3 class="sidebar-title">Jugadors</h3>
        <div id="player-list"></div>
      </div>
      <div class="sidebar-section">
        <h3 class="sidebar-title">Notes</h3>
        <textarea id="notes-area" class="notes-input" placeholder="Escriu les teves notes aquí..."></textarea>
      </div>
    </aside>

    <div class="grimoire-main">
      <div class="game-clock-widget">
        <div class="clock-widget-label">Cicle</div>
        <div class="cycle-main">
          <span id="cycle-icon" class="cycle-icon moon-icon" aria-hidden="true"></span>
          <div id="cycle-display" class="cycle-display">Nit 1</div>
        </div>
        <div class="cycle-actions">
          <button class="cycle-btn" id="cycle-prev" title="Fase anterior">−</button>
          <button class="cycle-btn" id="cycle-next" title="Fase següent">+</button>
        </div>
      </div>

      <div class="bell-timer-widget">
        <div class="clock-tower" aria-hidden="true">
          <div class="tower-storm"></div>
          <div class="tower-spire"></div>
          <div class="tower-roof"></div>
          <div class="tower-crown"></div>
          <div class="tower-clock"><span></span></div>
          <div class="tower-body"></div>
          <div class="tower-door"></div>
        </div>
        <div class="timer-controls">
          <div id="timer-display" class="timer-display">05:00</div>
          <div class="timer-row">
            <input id="timer-minutes" class="timer-input" type="number" min="1" max="99" value="5" aria-label="Minuts del temporitzador" />
            <button class="timer-btn" id="timer-toggle">Iniciar</button>
            <button class="timer-btn timer-reset" id="timer-reset">↺</button>
          </div>
        </div>
      </div>

      <div id="empty-state" class="empty-state" style="display:none">
        <div class="empty-state-icon">📖</div>
        <p>No hi ha cap partida activa.</p>
        <p style="font-size:.85rem;margin-top:.25rem">Afegeix jugadors o torna a la configuració.</p>
        <a href="/" class="btn btn-primary" style="margin-top:1.5rem;text-decoration:none">Anar a configuració</a>
      </div>
      <aside id="night-order-panel" class="night-order-panel" style="display:none" aria-live="polite">
        <div class="night-order-header">
          <div>
            <div class="night-order-kicker">Ordre de nit</div>
            <h2 id="night-order-title">Primera nit</h2>
          </div>
          <button class="night-order-close" id="close-night-order" title="Tancar">✕</button>
        </div>
        <div id="night-order-list" class="night-order-list"></div>
      </aside>
      <div id="grimoire-circle" class="grimoire-circle"></div>
    </div>
  </div>

  <!-- Token action modal -->
  <div id="token-modal" class="modal-overlay" style="display:none">
    <div class="modal">
      <div class="modal-header">
        <div style="display:flex;align-items:center;gap:.75rem">
          <div id="modal-token-img" class="modal-token"></div>
          <div>
            <h3 id="modal-char-name"></h3>
            <div id="modal-char-team" class="badge" style="margin-top:.25rem"></div>
          </div>
        </div>
        <button class="modal-close btn" id="close-token-modal">✕</button>
      </div>
      <div class="modal-body">
        <p id="modal-char-ability" style="color:var(--text-muted);font-size:.85rem;margin-bottom:1rem;font-style:italic"></p>
        <div class="modal-actions">
          <button class="modal-action-btn" id="btn-toggle-dead"></button>
          <button class="modal-action-btn" id="btn-toggle-poisoned">Enverinat</button>
          <button class="modal-action-btn" id="btn-toggle-drunk">Borratxo</button>
          <button class="modal-action-btn" id="btn-replace">Substituir</button>
          <button class="modal-action-btn" id="btn-add-reminder">Recordatori</button>
          <button class="modal-action-btn danger" id="btn-remove-player">Eliminar</button>
        </div>
        <div id="status-display" class="status-display"></div>
        <div id="reminders-display" style="margin-top:1rem"></div>
      </div>
    </div>
  </div>

  <!-- Character picker -->
  <div id="char-picker-modal" class="modal-overlay" style="display:none">
    <div class="modal" style="max-width:680px">
      <div class="modal-header">
        <h3 id="picker-title">Selecciona personatge</h3>
        <button class="modal-close btn" id="close-picker">✕</button>
      </div>
      <div class="modal-body">
        <input type="text" class="input" id="picker-search" placeholder="Cerca personatge..." style="margin-bottom:1rem" />
        <div class="team-filter-bar" id="picker-team-filter">
          <button class="team-filter-btn active" data-team="all">Tots</button>
          <button class="team-filter-btn team-townsfolk" data-team="townsfolk">Vilatans</button>
          <button class="team-filter-btn team-outsider" data-team="outsider">Forasters</button>
          <button class="team-filter-btn team-traveller" data-team="traveller">Viatgers</button>
          <button class="team-filter-btn team-minion" data-team="minion">Esbirros</button>
          <button class="team-filter-btn team-demon" data-team="demon">Dimonis</button>
        </div>
        <div id="char-picker-grid" class="char-picker-grid"></div>
      </div>
    </div>
  </div>

  <!-- QR Jugadors modal -->
  <div id="qr-modal" class="modal-overlay" style="display:none">
    <div class="modal" style="max-width:360px">
      <div class="modal-header">
        <h3>QR jugadors</h3>
        <button class="modal-close btn" id="close-qr">✕</button>
      </div>
      <div class="modal-body" style="display:flex;flex-direction:column;align-items:center;gap:1rem">
        <p style="font-size:.8rem;color:var(--text-muted);text-align:center">Els jugadors poden escanejar aquest codi per veure quins personatges hi ha a la partida.</p>
        <div id="qr-canvas-wrap" style="background:#fff;padding:.75rem;border-radius:8px"></div>
        <a id="qr-link" href="#" target="_blank" style="font-size:.72rem;color:var(--text-dim);word-break:break-all;text-align:center"></a>
      </div>
    </div>
  </div>

  <!-- Dimonis de farol modal -->
  <div id="farols-modal" class="modal-overlay" style="display:none">
    <div class="modal" style="max-width:680px">
      <div class="modal-header">
        <h3>🎭 Dimonis de farol</h3>
        <button class="modal-close btn" id="close-farols">✕</button>
      </div>
      <div class="modal-body">
        <p style="color:var(--text-muted);font-size:.85rem;margin-bottom:1rem">Personatges que el Dimoni pot fer servir com a farol.</p>
        <div id="farol-active-display"></div>
        <hr class="divider"/>
        <p style="color:var(--text-dim);font-size:.78rem;margin-bottom:.5rem">Canviar manualment:</p>
        <input type="text" class="input" id="farols-search" placeholder="Cerca personatge..." style="margin-bottom:.75rem" />
        <div class="team-filter-bar" id="farols-team-filter">
          <button class="team-filter-btn active" data-team="all">Tots</button>
          <button class="team-filter-btn team-townsfolk" data-team="townsfolk">Vilatans</button>
          <button class="team-filter-btn team-outsider" data-team="outsider">Forasters</button>
          <button class="team-filter-btn team-traveller" data-team="traveller">Viatgers</button>
          <button class="team-filter-btn team-minion" data-team="minion">Esbirros</button>
          <button class="team-filter-btn team-demon" data-team="demon">Dimonis</button>
        </div>
        <div id="farols-grid" class="char-picker-grid"></div>
      </div>
    </div>
  </div>
</Layout>

<script id="char-names-ca-data"     type="application/json" set:html={charNamesCaJson}></script>
<script id="char-abilities-ca-data" type="application/json" set:html={charAbilitiesCaJson}></script>

<script is:inline>
(async function () {
  const CDN = 'https://www.pocketgrimoire.co.uk';
  const NAMES_CA     = JSON.parse(document.getElementById('char-names-ca-data').textContent);
  const ABILITIES_CA = JSON.parse(document.getElementById('char-abilities-ca-data').textContent);
  function getNameCa(id, nameEn)     { return NAMES_CA[id]     ?? nameEn; }
  function getAbilityCa(id, abilityEn) { return ABILITIES_CA[id] ?? abilityEn; }
  function shortPower(char) {
    const text = getAbilityCa(char.id, char.ability || '').trim();
    return text.length > 190 ? `${text.slice(0, 187).trim()}...` : text;
  }
  function powerTooltipAttr(char) {
    const power = char ? shortPower(char) : '';
    return power ? ` data-power="${escapeHtml(power)}"` : '';
  }
  function getNightReminderCa(char, reminderKey) {
    return getAbilityCa(char.id, char.ability || char[reminderKey] || '');
  }
  const TEAM_LABELS = {townsfolk:'Vilatans',outsider:'Forasters',minion:'Esbirros',demon:'Dimonis',traveller:'Viatgers',fabled:'Llegendes'};

  let ALL_CHARS = [];
  try {
    const res = await fetch('/data/characters.json');
    ALL_CHARS = await res.json();
  } catch(e) { console.error('Error loading characters:', e); }

  let players = [], bluffs = [], notes = '', selectedSetupChars = [];
  let gameCycle = { phase: 'night', day: 0, night: 1 };
  let timerState = { seconds: 300, remaining: 300, running: false, interval: null, endsAt: null };
  let activeIdx = null, pickerMode = 'add';
  let dragState = null, suppressNextClick = false;
  let nightOrderOpen = false;
  let pickerTeamFilter = 'all';
  let farolsTeamFilter = 'all';

  function loadState() {
    try {
      const setup = JSON.parse(localStorage.getItem('botc_setup')||'{}');
      selectedSetupChars = setup.chars || [];
      const game = JSON.parse(localStorage.getItem('botc_game')||'{}');
      players = game.players || [];
      bluffs  = game.bluffs  || [];
      notes   = game.notes   || '';
      gameCycle = game.cycle || gameCycle;
      try {
        const savedTimer = JSON.parse(localStorage.getItem('botc_timer') || '{}');
        if (Number.isFinite(savedTimer.seconds)) timerState.seconds = savedTimer.seconds;
        if (Number.isFinite(savedTimer.remaining)) timerState.remaining = savedTimer.remaining;
      } catch(_) {}
      const custom = JSON.parse(localStorage.getItem('botc_custom_chars')||'[]');
      custom.forEach(c => { if(!ALL_CHARS.find(x=>x.id===c.id)) ALL_CHARS.push(c); });
      // Restore custom chars for players
      players.forEach(p => {
        if (p.customChar && !ALL_CHARS.find(x=>x.id===p.charId)) ALL_CHARS.push(p.customChar);
      });
    } catch(_) {}
  }

  function saveGame() {
    localStorage.setItem('botc_game', JSON.stringify({players, bluffs, notes, cycle: gameCycle}));
  }

  function saveTimer() {
    localStorage.setItem('botc_timer', JSON.stringify({
      seconds: timerState.seconds,
      remaining: timerState.remaining,
    }));
  }

  function imgUrl(id) {
    if (!id || id.startsWith('custom_')) return null;
    return `${CDN}/build/img/roles/${id}_g.webp`;
  }

  function charById(id) { return ALL_CHARS.find(c=>c.id===id); }

  function escapeHtml(value = '') {
    return String(value).replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
  }

  function cycleIndex(cycle = gameCycle) {
    return cycle.phase === 'night'
      ? ((cycle.night || 1) - 1) * 2
      : ((cycle.day || 1) - 1) * 2 + 1;
  }

  function isPoisoned(player) {
    return Number.isFinite(player?.poisonedUntil) && cycleIndex() <= player.poisonedUntil;
  }

  function isDrunk(player) {
    return !!player?.drunk;
  }

  function clearExpiredStatuses() {
    let changed = false;
    players.forEach(p => {
      if (Number.isFinite(p.poisonedUntil) && cycleIndex() > p.poisonedUntil) {
        delete p.poisonedUntil;
        changed = true;
      }
    });
    if (changed) saveGame();
  }

  function renderCycle() {
    const display = document.getElementById('cycle-display');
    if (!display) return;
    display.textContent = gameCycle.phase === 'night'
      ? `Nit ${gameCycle.night || 1}`
      : `Dia ${gameCycle.day || 1}`;
    display.classList.toggle('is-night', gameCycle.phase === 'night');
    display.classList.toggle('is-day', gameCycle.phase === 'day');
    const icon = document.getElementById('cycle-icon');
    if (icon) icon.className = `cycle-icon ${gameCycle.phase === 'night' ? 'moon-icon' : 'sun-icon'}`;
    renderNightOrderPanel();
  }

  function getNightOrderMode() {
    return gameCycle.phase === 'night' && (gameCycle.night || 1) === 1 ? 'first' : 'other';
  }

  function getNightOrderChars(mode = getNightOrderMode()) {
    const charIds = players.map(p => p.charId).filter(Boolean);
    const seen = new Set();
    const chars = charIds
      .map(id => charById(id))
      .filter(Boolean)
      .filter(c => {
        if (seen.has(c.id)) return false;
        seen.add(c.id);
        return true;
      });
    const orderKey = mode === 'first' ? 'firstNight' : 'otherNight';
    return chars.filter(c => c[orderKey] > 0).sort((a, b) => a[orderKey] - b[orderKey]);
  }

  function getNightOrderNumber(charId) {
    if (!nightOrderOpen || !charId) return null;
    const idx = getNightOrderChars().findIndex(c => c.id === charId);
    return idx >= 0 ? idx + 1 : null;
  }

  function renderNightOrderPanel() {
    const panel = document.getElementById('night-order-panel');
    if (!panel) return;
    panel.style.display = nightOrderOpen ? '' : 'none';
    document.getElementById('sb-night-order')?.classList.toggle('active', nightOrderOpen);
    if (!nightOrderOpen) return;

    const mode = getNightOrderMode();
    const title = mode === 'first' ? 'Primera nit' : 'Altres nits';
    const titleEl = document.getElementById('night-order-title');
    const listEl = document.getElementById('night-order-list');
    if (titleEl) titleEl.textContent = title;
    if (!listEl) return;

    const chars = getNightOrderChars(mode);
    const reminderKey = mode === 'first' ? 'firstNightReminder' : 'otherNightReminder';
    const systemRows = mode === 'first'
      ? [
          { label:'ESBIRROS', text:'El Narrador desperta els Esbirros i els mostra els altres Esbirros i qui és el Dimoni.' },
          { label:'DIMONI', text:'El Narrador desperta el Dimoni i li mostra els seus Esbirros i 3 personatges que no estan en joc.' },
        ]
      : [
          { label:'CREPUSCLE', text:'Preparació: recordatoris, Viatgers i Fabulosos.' },
        ];
    const charRows = chars.map((c, i) => {
      const url = imgUrl(c.id);
      return `<div class="night-order-row team-${c.team}">
        <div class="night-order-num">${i + 1}</div>
        <div class="night-order-token team-${c.team}">
          ${url ? `<img src="${url}" alt="${escapeHtml(getNameCa(c.id, c.name))}" onerror="this.style.display='none'" loading="lazy"/>` : `<span>${escapeHtml(getNameCa(c.id, c.name)[0] || '?')}</span>`}
        </div>
        <div class="night-order-content">
          <div class="night-order-name">${escapeHtml(getNameCa(c.id, c.name))}</div>
          <div class="night-order-reminder">${escapeHtml(getNightReminderCa(c, reminderKey) || '—')}</div>
        </div>
      </div>`;
    }).join('');
    const dawnRow = mode === 'other' && chars.length
      ? `<div class="night-order-row system-row">
          <div class="night-order-num">—</div>
          <div class="night-order-content">
            <div class="night-order-name system-label">ALBA</div>
            <div class="night-order-reminder">Tothom s'aixeca. Algú pot morir.</div>
          </div>
        </div>`
      : '';
    listEl.innerHTML = `${systemRows.map(row => `<div class="night-order-row system-row">
        <div class="night-order-num">—</div>
        <div class="night-order-content">
          <div class="night-order-name system-label">${row.label}</div>
          <div class="night-order-reminder">${row.text}</div>
        </div>
      </div>`).join('')}${charRows || '<p class="night-order-empty">Cap personatge actiu en aquesta fase.</p>'}${dawnRow}`;
  }

  function toggleNightOrderPanel() {
    nightOrderOpen = !nightOrderOpen;
    renderNightOrderPanel();
    renderCircle();
  }

  function advanceCycle(step) {
    if (step > 0) {
      if (gameCycle.phase === 'night') {
        gameCycle.phase = 'day';
        gameCycle.day = Math.max(gameCycle.day || 0, gameCycle.night || 1);
      } else {
        gameCycle.phase = 'night';
        gameCycle.night = (gameCycle.night || 1) + 1;
      }
    } else if (gameCycle.phase === 'day') {
      gameCycle.phase = 'night';
      gameCycle.night = Math.max(1, gameCycle.day || 1);
    } else if ((gameCycle.night || 1) > 1) {
      gameCycle.phase = 'day';
      gameCycle.day = (gameCycle.night || 1) - 1;
    }
    clearExpiredStatuses();
    saveGame();
    renderCycle();
    renderCircle();
  }

  function formatTimer(seconds) {
    const s = Math.max(0, Math.floor(seconds));
    return `${String(Math.floor(s / 60)).padStart(2,'0')}:${String(s % 60).padStart(2,'0')}`;
  }

  function renderTimer() {
    const display = document.getElementById('timer-display');
    const toggle = document.getElementById('timer-toggle');
    const input = document.getElementById('timer-minutes');
    if (!display || !toggle || !input) return;
    display.textContent = formatTimer(timerState.remaining);
    display.classList.toggle('timer-done', timerState.remaining <= 0);
    toggle.textContent = timerState.running ? 'Pausar' : 'Iniciar';
    input.disabled = timerState.running;
    input.value = String(Math.max(1, Math.round(timerState.seconds / 60)));
  }

  function setTimerFromInput() {
    const minutes = Math.max(1, Math.min(99, +(document.getElementById('timer-minutes')?.value || 5)));
    timerState.seconds = minutes * 60;
    timerState.remaining = timerState.seconds;
    saveTimer();
    renderTimer();
  }

  function toggleTimer() {
    if (timerState.running) { pauseTimer(); return; }
    if (timerState.remaining <= 0) setTimerFromInput();
    timerState.running = true;
    timerState.endsAt = Date.now() + timerState.remaining * 1000;
    timerState.interval = window.setInterval(tickTimer, 250);
    renderTimer();
  }

  function pauseTimer() {
    timerState.running = false;
    if (timerState.interval) window.clearInterval(timerState.interval);
    timerState.interval = null;
    saveTimer();
    renderTimer();
  }

  function resetTimer() {
    pauseTimer();
    setTimerFromInput();
  }

  function tickTimer() {
    timerState.remaining = Math.max(0, Math.ceil((timerState.endsAt - Date.now()) / 1000));
    if (timerState.remaining <= 0) {
      pauseTimer();
      timerState.remaining = 0;
      saveTimer();
      renderTimer();
      ringBell();
      return;
    }
    renderTimer();
  }

  function ringBell() {
    const AudioCtx = window.AudioContext || window.webkitAudioContext;
    if (!AudioCtx) return;
    const ctx = new AudioCtx();
    const master = ctx.createGain();
    master.gain.value = 0.72;
    master.connect(ctx.destination);
    const strike = delay => {
      const start = ctx.currentTime + delay;
      const bellGain = ctx.createGain();
      bellGain.gain.setValueAtTime(0.0001, start);
      bellGain.gain.exponentialRampToValueAtTime(0.75, start + 0.025);
      bellGain.gain.exponentialRampToValueAtTime(0.0001, start + 5.8);
      bellGain.connect(master);
      [82, 123, 164, 247, 330, 494].forEach((freq, i) => {
        const osc = ctx.createOscillator();
        osc.type = i < 2 ? 'sine' : 'triangle';
        osc.frequency.setValueAtTime(freq, start);
        osc.frequency.exponentialRampToValueAtTime(freq * 0.985, start + 1.2);
        osc.detune.setValueAtTime((i - 2) * 5, start);
        osc.connect(bellGain);
        osc.start(start);
        osc.stop(start + 5.9);
      });
      const noiseBuffer = ctx.createBuffer(1, ctx.sampleRate * 0.18, ctx.sampleRate);
      const data = noiseBuffer.getChannelData(0);
      for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1) * (1 - i / data.length);
      const noise = ctx.createBufferSource();
      const noiseGain = ctx.createGain();
      noise.buffer = noiseBuffer;
      noiseGain.gain.setValueAtTime(0.12, start);
      noiseGain.gain.exponentialRampToValueAtTime(0.0001, start + 0.2);
      noise.connect(noiseGain);
      noiseGain.connect(master);
      noise.start(start);
    };
    strike(0); strike(1.35); strike(2.7); strike(4.05);
  }

  // Circle
  function renderCircle() {
    const circle = document.getElementById('grimoire-circle');
    const empty  = document.getElementById('empty-state');
    if (!circle) return;
    if (!players.length) { circle.style.display='none'; empty.style.display=''; renderPlayerList(); return; }
    circle.style.display=''; empty.style.display='none';
    circle.innerHTML = `<div class="tokens-ring">${players.map((p,i) => {
      const char = p.charId ? charById(p.charId) : null;
      const url = char ? imgUrl(char.id) : null;
      const nightOrderNum = getNightOrderNumber(p.charId);
      return `<div class="circle-token has-power-tooltip team-${char?.team||'townsfolk'} ${p.dead?'dead':''}" data-idx="${i}"${char ? powerTooltipAttr(char) : ''} style="position:absolute">
        ${url ? `<img src="${url}" alt="${getNameCa(char.id, char.name)}" onerror="this.style.display='none'" loading="lazy"/>` : `<span class="token-placeholder">${i+1}</span>`}
        ${nightOrderNum ? `<div class="night-order-marker">${nightOrderNum}</div>` : ''}
        ${p.dead ? '<div class="dead-shroud">†</div>' : ''}
        <div class="token-status-tags">
          ${isPoisoned(p) ? '<span class="token-status poisoned">Enverinat</span>' : ''}
          ${isDrunk(p) ? '<span class="token-status drunk">Borratxo</span>' : ''}
        </div>
        <div class="token-label">${p.name||`J${i+1}`}</div>
        ${char ? `<div class="token-char-name">${getNameCa(char.id, char.name)}</div>` : ''}
      </div>`;
    }).join('')}</div>`;
    circle.querySelectorAll('.circle-token').forEach(el => {
      el.addEventListener('pointerdown', startTokenDrag);
      el.addEventListener('click', () => {
        if (suppressNextClick) return;
        openTokenModal(+el.dataset.idx);
      });
    });
    positionTokens();
    renderPlayerList();
  }

  function positionTokens() {
    const ring = document.querySelector('.tokens-ring');
    if (!ring) return;
    const items = ring.querySelectorAll('.circle-token');
    const N = items.length; if (!N) return;
    const W = ring.offsetWidth||600, H = ring.offsetHeight||600;
    const cx=W/2, cy=H/2;
    const r = Math.min(cx,cy)*0.78;
    const tokenW = 80;
    items.forEach((el,i) => {
      const p = players[i];
      let centerX, centerY;
      if (Number.isFinite(p?.posX) && Number.isFinite(p?.posY)) {
        centerX = p.posX * W;
        centerY = p.posY * H;
      } else {
        const angle = (2*Math.PI*i/N) - Math.PI/2;
        centerX = cx + r*Math.cos(angle);
        centerY = cy + r*Math.sin(angle);
      }
      el.style.left = `${Math.max(0, Math.min(W-tokenW, centerX - tokenW/2))}px`;
      el.style.top  = `${Math.max(0, Math.min(H-tokenW, centerY - tokenW/2))}px`;
    });
  }

  function startTokenDrag(e) {
    if (e.button !== undefined && e.button !== 0) return;
    e.preventDefault();
    const el = e.currentTarget;
    const ring = document.querySelector('.tokens-ring');
    if (!ring) return;
    const idx = +el.dataset.idx;
    const ringRect = ring.getBoundingClientRect();
    const tokenRect = el.getBoundingClientRect();
    dragState = {
      el, ring, idx, ringRect,
      startX: e.clientX,
      startY: e.clientY,
      offsetX: e.clientX - tokenRect.left,
      offsetY: e.clientY - tokenRect.top,
      moved: false,
    };
    el.classList.add('dragging');
    el.setPointerCapture?.(e.pointerId);
    window.addEventListener('pointermove', dragToken);
    window.addEventListener('pointerup', endTokenDrag, { once: true });
  }

  function dragToken(e) {
    if (!dragState) return;
    e.preventDefault();
    const { el, ringRect, offsetX, offsetY, startX, startY } = dragState;
    const tokenW = el.offsetWidth || 80;
    const tokenH = el.offsetHeight || 80;
    const dx = e.clientX - startX;
    const dy = e.clientY - startY;
    if (Math.hypot(dx, dy) > 4) dragState.moved = true;
    const left = Math.max(0, Math.min(ringRect.width - tokenW, e.clientX - ringRect.left - offsetX));
    const top = Math.max(0, Math.min(ringRect.height - tokenH, e.clientY - ringRect.top - offsetY));
    el.style.left = `${left}px`;
    el.style.top = `${top}px`;
  }

  function endTokenDrag() {
    if (!dragState) return;
    window.removeEventListener('pointermove', dragToken);
    const { el, ringRect, idx, moved } = dragState;
    el.classList.remove('dragging');
    if (moved) {
      const tokenW = el.offsetWidth || 80;
      const tokenH = el.offsetHeight || 80;
      const left = parseFloat(el.style.left) || 0;
      const top = parseFloat(el.style.top) || 0;
      players[idx].posX = (left + tokenW / 2) / ringRect.width;
      players[idx].posY = (top + tokenH / 2) / ringRect.height;
      saveGame();
      suppressNextClick = true;
      setTimeout(() => { suppressNextClick = false; }, 160);
    }
    dragState = null;
  }

  function renderPlayerList() {
    const list = document.getElementById('player-list');
    if (!list) return;
    if (!players.length) { list.innerHTML='<p style="color:var(--text-dim);font-size:.8rem">Cap jugador. Afegeix-ne un!</p>'; return; }
    list.innerHTML = players.map((p,i) => {
      const char = p.charId ? charById(p.charId) : null;
      const url = char ? imgUrl(char.id) : null;
      return `<div class="player-item ${p.dead?'dead':''}" data-idx="${i}">
        <div class="player-token-sm team-${char?.team||'townsfolk'}">
          ${url ? `<img src="${url}" alt="${getNameCa(char.id, char.name)}" onerror="this.style.display='none'" loading="lazy"/>` : `<span>${i+1}</span>`}
        </div>
        <div class="player-info">
          <span class="player-name">${p.name||`Jugador ${i+1}`}</span>
          ${char ? `<span class="player-char">${getNameCa(char.id, char.name)}</span>` : ''}
          ${(isPoisoned(p) || isDrunk(p)) ? `<span class="player-status-line">${isPoisoned(p)?'Enverinat':''}${isPoisoned(p)&&isDrunk(p)?' · ':''}${isDrunk(p)?'Borratxo':''}</span>` : ''}
        </div>
        ${p.dead ? '<span class="dead-badge">†</span>' : ''}
      </div>`;
    }).join('');
    list.querySelectorAll('.player-item').forEach(el => {
      el.addEventListener('click', () => openTokenModal(+el.dataset.idx));
    });
  }

  // Token modal
  function openTokenModal(idx) {
    activeIdx = idx;
    const p = players[idx];
    const char = p.charId ? charById(p.charId) : null;
    document.getElementById('modal-char-name').textContent = char ? getNameCa(char.id, char.name) : `Jugador ${idx+1}`;
    document.getElementById('modal-char-ability').textContent = char ? getAbilityCa(char.id, char.ability||'') : '';
    const teamEl = document.getElementById('modal-char-team');
    teamEl.textContent = char ? (TEAM_LABELS[char.team]||char.team) : '';
    teamEl.className = `badge team-${char?.team||'townsfolk'}`;
    document.getElementById('btn-toggle-dead').textContent = p.dead ? 'Revifar' : 'Emmortallar';
    renderStatusControls(p);
    const img = document.getElementById('modal-token-img');
    img.className = `modal-token team-${char?.team||'townsfolk'}`;
    const url = char ? imgUrl(char.id) : null;
    img.innerHTML = url ? `<img src="${url}" alt="${getNameCa(char.id, char.name)}" onerror="this.style.display='none'" loading="lazy"/>` : `<span>${idx+1}</span>`;
    renderReminders(p);
    document.getElementById('token-modal').style.display = '';
  }

  function renderStatusControls(p) {
    const poisoned = isPoisoned(p);
    const drunk = isDrunk(p);
    const poisonedBtn = document.getElementById('btn-toggle-poisoned');
    const drunkBtn = document.getElementById('btn-toggle-drunk');
    poisonedBtn.classList.toggle('active-status', poisoned);
    drunkBtn.classList.toggle('active-status', drunk);
    poisonedBtn.textContent = poisoned ? 'Treure enverinat' : 'Enverinat';
    drunkBtn.textContent = drunk ? 'Treure borratxo' : 'Borratxo';
    const statuses = [];
    if (poisoned) statuses.push('<span class="status-tag poisoned">Enverinat fins al proper dia</span>');
    if (drunk) statuses.push('<span class="status-tag drunk">Borratxo</span>');
    document.getElementById('status-display').innerHTML = statuses.join('');
  }

  function renderReminders(p) {
    const el = document.getElementById('reminders-display');
    if (!p.reminders?.length) { el.innerHTML=''; return; }
    el.innerHTML = `<p style="color:var(--text-muted);font-size:.8rem;margin-bottom:.5rem">Recordatoris:</p>
      <div style="display:flex;flex-wrap:wrap;gap:.5rem">
        ${p.reminders.map((r,ri) => `<span class="reminder-tag" data-ri="${ri}">${r} ✕</span>`).join('')}
      </div>`;
    el.querySelectorAll('.reminder-tag').forEach(tag => {
      tag.addEventListener('click', () => {
        players[activeIdx].reminders.splice(+tag.dataset.ri, 1);
        saveGame(); renderReminders(players[activeIdx]); renderCircle();
      });
    });
  }

  document.getElementById('close-token-modal').addEventListener('click', () => { document.getElementById('token-modal').style.display='none'; activeIdx=null; });
  document.getElementById('token-modal').addEventListener('click', e => { if(e.target===e.currentTarget){e.currentTarget.style.display='none'; activeIdx=null;} });

  document.getElementById('btn-toggle-dead').addEventListener('click', () => {
    if (activeIdx===null) return;
    players[activeIdx].dead = !players[activeIdx].dead;
    document.getElementById('btn-toggle-dead').textContent = players[activeIdx].dead ? 'Revifar' : 'Emmortallar';
    saveGame(); renderCircle();
  });

  document.getElementById('btn-toggle-poisoned').addEventListener('click', () => {
    if (activeIdx===null) return;
    const p = players[activeIdx];
    if (isPoisoned(p)) delete p.poisonedUntil;
    else p.poisonedUntil = gameCycle.phase === 'night' ? cycleIndex() + 1 : cycleIndex();
    saveGame();
    renderStatusControls(p);
    renderCircle();
  });

  document.getElementById('btn-toggle-drunk').addEventListener('click', () => {
    if (activeIdx===null) return;
    const p = players[activeIdx];
    p.drunk = !p.drunk;
    saveGame();
    renderStatusControls(p);
    renderCircle();
  });

  document.getElementById('btn-remove-player').addEventListener('click', () => {
    if (activeIdx===null) return;
    players.splice(activeIdx,1);
    saveGame(); document.getElementById('token-modal').style.display='none'; activeIdx=null; renderCircle();
  });

  document.getElementById('btn-add-reminder').addEventListener('click', () => {
    if (activeIdx===null) return;
    const char = players[activeIdx].charId ? charById(players[activeIdx].charId) : null;
    const reminders = char?.reminders || [];
    let chosen;
    if (!reminders.length) { chosen = prompt('Recordatori personalitzat:'); }
    else {
      const opts = reminders.map((r,i)=>`${i+1}. ${r}`).join('\n');
      const n = prompt(`Selecciona:\n${opts}\n0. Personalitzat`);
      if (n===null) return;
      chosen = +n===0 ? prompt('Recordatori personalitzat:') : reminders[+n-1];
    }
    if (chosen?.trim()) { players[activeIdx].reminders.push(chosen.trim()); saveGame(); renderReminders(players[activeIdx]); renderCircle(); }
  });

  document.getElementById('btn-replace').addEventListener('click', () => {
    pickerMode='replace';
    document.getElementById('picker-title').textContent='Substituir personatge';
    document.getElementById('picker-search').value='';
    pickerTeamFilter = 'all';
    syncTeamFilter('picker-team-filter', pickerTeamFilter);
    renderPickerGrid('');
    document.getElementById('char-picker-modal').style.display='';
    document.getElementById('token-modal').style.display='none';
  });

  // Character picker
  document.getElementById('sb-add-player').addEventListener('click', () => {
    pickerMode='add';
    document.getElementById('picker-title').textContent='Afegeix jugador';
    document.getElementById('picker-search').value='';
    pickerTeamFilter = 'all';
    syncTeamFilter('picker-team-filter', pickerTeamFilter);
    renderPickerGrid('');
    document.getElementById('char-picker-modal').style.display='';
  });
  document.getElementById('close-picker').addEventListener('click', () => { document.getElementById('char-picker-modal').style.display='none'; });
  document.getElementById('char-picker-modal').addEventListener('click', e => { if(e.target===e.currentTarget) e.currentTarget.style.display='none'; });
  document.getElementById('picker-search').addEventListener('input', e => renderPickerGrid(e.target.value.toLowerCase()));
  document.querySelectorAll('#picker-team-filter .team-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      pickerTeamFilter = btn.dataset.team;
      syncTeamFilter('picker-team-filter', pickerTeamFilter);
      renderPickerGrid(document.getElementById('picker-search').value.toLowerCase());
    });
  });

  function renderPickerGrid(q) {
    const inUse = new Set(players.map(p=>p.charId).filter(Boolean));
    let chars = selectedSetupChars.length ? ALL_CHARS.filter(c=>selectedSetupChars.includes(c.id)) : ALL_CHARS.filter(c=>['tb','bmr','snv'].includes(c.edition)||c.id.startsWith('custom_'));
    if (pickerTeamFilter !== 'all') chars = chars.filter(c=>c.team === pickerTeamFilter);
    if (q) chars = chars.filter(c=>c.name.toLowerCase().includes(q) || getNameCa(c.id, c.name).toLowerCase().includes(q));
    const grid = document.getElementById('char-picker-grid');
    if (!chars.length) { grid.innerHTML='<p style="color:var(--text-muted);text-align:center;padding:2rem">Cap resultat.</p>'; return; }
    grid.innerHTML = chars.map(c => {
      const url = imgUrl(c.id);
      const name = getNameCa(c.id, c.name);
      return `<button class="picker-char has-power-tooltip ${inUse.has(c.id)?'in-use':''} team-${c.team}" data-id="${c.id}"${powerTooltipAttr(c)}>
        <div class="picker-img team-${c.team}">${url?`<img src="${url}" alt="${name}" onerror="this.style.display='none'" loading="lazy"/>`:`<span>${name[0]}</span>`}</div>
        <span>${name}</span>
        ${inUse.has(c.id)?'<span class="in-use-badge">·</span>':''}
      </button>`;
    }).join('');
    grid.querySelectorAll('.picker-char').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id;
        if (pickerMode==='add') {
          const name = prompt(`Nom del jugador ${players.length+1} (opcional):`);
          players.push({id:Date.now(), name:name?.trim()||`Jugador ${players.length+1}`, charId:id, dead:false, reminders:[]});
        } else if (pickerMode==='replace' && activeIdx!==null) {
          players[activeIdx].charId = id;
        }
        saveGame(); document.getElementById('char-picker-modal').style.display='none'; renderCircle();
      });
    });
  }

  // Dimonis de farol
  document.getElementById('sb-farols').addEventListener('click', () => {
    document.getElementById('farols-search').value = '';
    farolsTeamFilter = 'all';
    syncTeamFilter('farols-team-filter', farolsTeamFilter);
    renderFarolsModal();
    document.getElementById('farols-modal').style.display='';
  });
  document.getElementById('close-farols').addEventListener('click', () => { document.getElementById('farols-modal').style.display='none'; });
  document.getElementById('farols-modal').addEventListener('click', e => { if(e.target===e.currentTarget) e.currentTarget.style.display='none'; });
  document.getElementById('farols-search').addEventListener('input', renderFarolsModal);
  document.querySelectorAll('#farols-team-filter .team-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      farolsTeamFilter = btn.dataset.team;
      syncTeamFilter('farols-team-filter', farolsTeamFilter);
      renderFarolsModal();
    });
  });

  function syncTeamFilter(filterId, activeTeam) {
    document.querySelectorAll(`#${filterId} .team-filter-btn`).forEach(btn => {
      btn.classList.toggle('active', btn.dataset.team === activeTeam);
    });
  }

  function renderFarolsModal() {
    const activeEl = document.getElementById('farol-active-display');
    if (bluffs.length) {
      const farolChars = bluffs.map(id=>charById(id)).filter(Boolean);
      activeEl.innerHTML = `<div style="display:flex;flex-wrap:wrap;gap:.75rem;margin-bottom:.5rem">${farolChars.map(c => {
        const url = imgUrl(c.id);
        const name = getNameCa(c.id, c.name);
        return `<div style="display:flex;flex-direction:column;align-items:center;gap:.3rem">
          <div class="picker-img team-${c.team}" style="width:52px;height:52px">${url?`<img src="${url}" alt="${name}" onerror="this.style.display='none'" loading="lazy"/>`:`<span>${name[0]}</span>`}</div>
          <span style="font-size:.7rem;color:var(--accent)">${name}</span>
        </div>`;
      }).join('')}</div>`;
    } else {
      activeEl.innerHTML = '<p style="color:var(--text-dim);font-size:.82rem;margin-bottom:.5rem">Cap farol actiu. Randomitza des de la configuració o tria manualment.</p>';
    }
    const inUse = new Set(players.map(p=>p.charId).filter(Boolean));
    let chars = selectedSetupChars.length ? ALL_CHARS.filter(c=>selectedSetupChars.includes(c.id)) : ALL_CHARS.filter(c=>['tb','bmr','snv'].includes(c.edition)||c.id.startsWith('custom_'));
    chars = chars.filter(c=>!inUse.has(c.id));
    if (farolsTeamFilter !== 'all') chars = chars.filter(c=>c.team === farolsTeamFilter);
    const q = (document.getElementById('farols-search')?.value || '').trim().toLowerCase();
    if (q) chars = chars.filter(c=>c.name.toLowerCase().includes(q) || getNameCa(c.id, c.name).toLowerCase().includes(q));
    const grid = document.getElementById('farols-grid');
    grid.innerHTML = chars.map(c => {
      const url = imgUrl(c.id);
      const name = getNameCa(c.id, c.name);
      return `<button class="picker-char has-power-tooltip ${bluffs.includes(c.id)?'bluff-selected':''} team-${c.team}" data-id="${c.id}"${powerTooltipAttr(c)}>
        <div class="picker-img team-${c.team}">${url?`<img src="${url}" alt="${name}" onerror="this.style.display='none'" loading="lazy"/>`:`<span>${name[0]}</span>`}</div>
        <span>${name}</span>
        ${bluffs.includes(c.id)?'<span class="bluff-badge">🎭</span>':''}
      </button>`;
    }).join('');
    grid.querySelectorAll('.picker-char').forEach(btn => {
      btn.addEventListener('click', () => {
        const id=btn.dataset.id, idx=bluffs.indexOf(id);
        if(idx>=0){bluffs.splice(idx,1);btn.classList.remove('bluff-selected');}
        else{bluffs.push(id);btn.classList.add('bluff-selected');}
        saveGame(); renderFarolsModal();
      });
    });
  }

  // QR Jugadors
  let qrLibLoaded = false;
  async function loadQrLib() {
    if (qrLibLoaded) return;
    await new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js';
      s.onload = resolve; s.onerror = reject;
      document.head.appendChild(s);
    });
    qrLibLoaded = true;
  }
  document.getElementById('sb-qr').addEventListener('click', async () => {
    const charIds = players.map(p=>p.charId).filter(Boolean);
    if (!charIds.length) { alert('No hi ha cap jugador a la partida.'); return; }
    const url = `${location.origin}/full?chars=${charIds.join(',')}`;
    const wrap = document.getElementById('qr-canvas-wrap');
    const link = document.getElementById('qr-link');
    link.href = url; link.textContent = url;
    wrap.innerHTML = '';
    try {
      await loadQrLib();
      new QRCode(wrap, { text: url, width: 220, height: 220, colorDark: '#000', colorLight: '#fff', correctLevel: QRCode.CorrectLevel.M });
    } catch(_) {
      wrap.innerHTML = `<p style="color:var(--red-light);font-size:.8rem">No s'ha pogut generar el QR. <a href="${url}" target="_blank" style="color:var(--accent)">Obre l'enllaç</a></p>`;
    }
    document.getElementById('qr-modal').style.display = '';
  });
  document.getElementById('close-qr').addEventListener('click', () => { document.getElementById('qr-modal').style.display='none'; });
  document.getElementById('qr-modal').addEventListener('click', e => { if(e.target===e.currentTarget) e.currentTarget.style.display='none'; });

  // Ordre de Nit
  document.getElementById('sb-night-order').addEventListener('click', toggleNightOrderPanel);
  document.getElementById('close-night-order').addEventListener('click', () => {
    nightOrderOpen = false;
    renderNightOrderPanel();
    renderCircle();
  });

  // Notes
  document.getElementById('notes-area').addEventListener('input', e => { notes=e.target.value; saveGame(); });

  document.getElementById('cycle-prev').addEventListener('click', () => advanceCycle(-1));
  document.getElementById('cycle-next').addEventListener('click', () => advanceCycle(1));
  document.getElementById('timer-minutes').addEventListener('change', setTimerFromInput);
  document.getElementById('timer-toggle').addEventListener('click', toggleTimer);
  document.getElementById('timer-reset').addEventListener('click', resetTimer);

  // Clear
  document.getElementById('sb-clear').addEventListener('click', () => {
    if (!confirm('Segur que vols iniciar una nova partida?')) return;
    players=[]; bluffs=[]; notes='';
    saveGame(); document.getElementById('notes-area').value=''; renderCircle();
  });

  window.addEventListener('resize', positionTokens);

  // Init
  loadState();
  clearExpiredStatuses();
  renderCycle();
  renderTimer();
  renderCircle();
  document.getElementById('notes-area').value = notes;
})();
</script>

<style is:global>
.grimoire-page { display:flex; height:calc(100vh - 53px); overflow:hidden; }
