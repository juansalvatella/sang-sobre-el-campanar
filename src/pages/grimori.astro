---
import Layout from '../layouts/Layout.astro';
import { ca } from '../i18n/ca';
import charactersRaw from '../data/characters.json';

type Character = {
  id: string;
  name: string;
  edition: string;
  team: string;
  firstNight: number;
  firstNightReminder: string;
  otherNight: number;
  otherNightReminder: string;
  reminders: string[];
  setup: boolean;
  ability: string;
  image: string;
};

const characters = charactersRaw as Character[];
const charactersJson = JSON.stringify(characters);
const POCKETGRIMOIRE_CDN = 'https://www.pocketgrimoire.co.uk';
---

<Layout title={ca.grimoire.title} activePage="grimoire">
  <div class="grimoire-page">

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-section">
        <h3 class="sidebar-title">Partida</h3>
        <button class="sidebar-btn" onclick="openAddTokenModal()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zm-7 14-5-5 1.41-1.41L12 14.17l7.59-7.59L21 8l-9 9z"/></svg>
          Afegeix Jugador
        </button>
        <button class="sidebar-btn" onclick="openBluffsModal()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>
          Dimonis de Farol
        </button>
        <button class="sidebar-btn" onclick="window.location.href='/ordre-de-nit'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11.1 12.08c-2.33-4.51-.5-8.48.53-10.07C6.27 2.2 1.98 6.59 1.98 12c0 .14.02.28.02.42.62-.27 1.29-.42 2-.42 1.66 0 3.18.83 4.1 2.1A4.98 4.98 0 0 1 12 13c.08 0 .16.01.24.02C12.12 12.64 11.74 12.38 11.1 12.08z"/></svg>
          {ca.grimoire.nightOrder}
        </button>
        <button class="sidebar-btn danger" onclick="clearGame()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
          Nova Partida
        </button>
      </div>

      <div class="sidebar-section">
        <h3 class="sidebar-title">Jugadors</h3>
        <div id="player-list" class="player-list"></div>
      </div>

      <div class="sidebar-section">
        <h3 class="sidebar-title">Notes</h3>
        <textarea
          id="notes-area"
          class="notes-input"
          placeholder={ca.notes.placeholder}
          oninput="saveNotes(this.value)"
        ></textarea>
      </div>
    </aside>

    <!-- Main grimoire area -->
    <div class="grimoire-main">
      <div id="empty-state" class="empty-state" style="display:none">
        <div class="empty-state-icon">📖</div>
        <p>No hi ha cap partida activa.</p>
        <p style="font-size:0.85rem; margin-top:0.25rem">Afegeix jugadors al panel lateral o torna a la configuració.</p>
        <a href="/" class="btn btn-primary" style="margin-top:1.5rem; text-decoration:none">
          Anar a Configuració
        </a>
      </div>

      <!-- Token circle -->
      <div id="grimoire-circle" class="grimoire-circle">
        <!-- tokens injected by JS -->
      </div>

      <!-- Reminder tokens floating -->
      <div id="reminder-area" class="reminder-area"></div>
    </div>
  </div>

  <!-- Token action modal -->
  <div id="token-modal" class="modal-overlay" style="display:none" onclick="closeTokenModal(event)">
    <div class="modal" onclick="event.stopPropagation()">
      <div class="modal-header">
        <div style="display:flex;align-items:center;gap:0.75rem">
          <div id="modal-token-img" class="modal-token"></div>
          <div>
            <h3 id="modal-char-name"></h3>
            <div id="modal-char-team" class="badge" style="margin-top:0.25rem"></div>
          </div>
        </div>
        <button class="modal-close btn" onclick="closeTokenModal()">✕</button>
      </div>
      <div class="modal-body">
        <p id="modal-char-ability" style="color:var(--text-muted); font-size:0.85rem; margin-bottom:1rem; font-style:italic"></p>
        <div class="modal-actions">
          <button class="modal-action-btn" onclick="toggleDead()">
            <span id="dead-label">Emmortallar</span>
          </button>
          <button class="modal-action-btn" onclick="openReplaceModal()">
            Substituir
          </button>
          <button class="modal-action-btn" onclick="addReminderToPlayer()">
            Recordatori
          </button>
          <button class="modal-action-btn danger" onclick="removePlayer()">
            Eliminar
          </button>
        </div>
        <div id="reminders-display" style="margin-top:1rem"></div>
      </div>
    </div>
  </div>

  <!-- Add player / replace modal -->
  <div id="char-picker-modal" class="modal-overlay" style="display:none" onclick="closeCharPicker(event)">
    <div class="modal" style="max-width:680px" onclick="event.stopPropagation()">
      <div class="modal-header">
        <h3 id="picker-title">Selecciona Personatge</h3>
        <button class="modal-close btn" onclick="closeCharPicker()">✕</button>
      </div>
      <div class="modal-body">
        <input
          type="text"
          class="input"
          placeholder="Cerca personatge..."
          id="char-search"
          oninput="filterCharPicker(this.value)"
          style="margin-bottom:1rem"
        />
        <div id="char-picker-grid" class="char-picker-grid"></div>
      </div>
    </div>
  </div>

  <!-- Dimonis de Farol modal -->
  <div id="bluffs-modal" class="modal-overlay" style="display:none" onclick="closeBluffs(event)">
    <div class="modal" style="max-width:680px" onclick="event.stopPropagation()">
      <div class="modal-header">
        <h3>🎭 Dimonis de Farol</h3>
        <button class="modal-close btn" onclick="closeBluffs()">✕</button>
      </div>
      <div class="modal-body">
        <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:1rem">
          Personatges que el Dimoni pot fer servir com a farol. Seleccionats automàticament al randomitzar, o tria manualment.
        </p>
        <div id="farol-active" class="farol-active-display"></div>
        <hr class="divider"/>
        <p style="color:var(--text-dim);font-size:0.78rem;margin-bottom:0.5rem">Canviar farol manualment:</p>
        <div id="bluffs-grid" class="char-picker-grid"></div>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ charactersJson, POCKETGRIMOIRE_CDN }}>
  const ALL_CHARS = JSON.parse(charactersJson);
  const CDN = POCKETGRIMOIRE_CDN;

  // State
  let players = [];    // { id, name, charId, dead, reminders: [] }
  let bluffs = [];     // charIds
  let notes = '';
  let selectedSetupChars = [];
  let activePlayerIdx = null;
  let pickerMode = 'add'; // 'add' | 'replace'

  const TEAM_LABELS = {
    townsfolk: 'Habitants',
    outsider: 'Forasters',
    minion: 'Servents',
    demon: 'Dimonis',
    traveller: 'Viatgers',
    fabled: 'Llegendes',
  };

  function imgUrl(id) {
    return `${CDN}/build/img/roles/${id}_g.webp`;
  }

  function charById(id) {
    return ALL_CHARS.find(c => c.id === id);
  }

  // Load state
  function loadState() {
    try {
      const setup = JSON.parse(localStorage.getItem('botc_setup') || '{}');
      selectedSetupChars = setup.chars || [];

      const game = JSON.parse(localStorage.getItem('botc_game') || '{}');
      players = game.players || [];
      bluffs  = game.bluffs  || [];
      notes   = game.notes   || '';

      // Merge custom chars into ALL_CHARS lookup
      const customChars = JSON.parse(localStorage.getItem('botc_custom_chars') || '[]');
      customChars.forEach(c => {
        if (!ALL_CHARS.find(x => x.id === c.id)) ALL_CHARS.push(c);
      });
    } catch(_) {}
  }

  function saveGameState() {
    localStorage.setItem('botc_game', JSON.stringify({ players, bluffs, notes }));
  }

  // Render token circle
  function renderCircle() {
    const circle = document.getElementById('grimoire-circle');
    const empty  = document.getElementById('empty-state');

    if (players.length === 0) {
      circle.style.display = 'none';
      empty.style.display = '';
      renderPlayerList();
      return;
    }

    circle.style.display = '';
    empty.style.display  = 'none';

    const N = players.length;
    const tokens = players.map((p, i) => {
      const char = p.charId ? charById(p.charId) : null;
      const team = char ? char.team : 'townsfolk';
      return `
        <div
          class="circle-token team-${team} ${p.dead ? 'dead' : ''}"
          data-idx="${i}"
          onclick="openTokenModal(${i})"
          title="${p.name || `Jugador ${i+1}`}${char ? ` — ${char.name}` : ''}"
        >
          ${char
            ? `<img src="${imgUrl(char.id)}" alt="${char.name}"
                onerror="this.style.display='none'" loading="lazy"/>`
            : `<span class="token-placeholder">${i+1}</span>`
          }
          ${p.dead ? '<div class="dead-shroud">†</div>' : ''}
          <div class="token-label">${p.name || `J${i+1}`}</div>
          ${char ? `<div class="token-char-name">${char.name}</div>` : ''}
        </div>
      `;
    }).join('');

    circle.innerHTML = `<div class="tokens-ring">${tokens}</div>`;
    positionTokens();
    renderPlayerList();
  }

  function positionTokens() {
    const ring = document.querySelector('.tokens-ring');
    if (!ring) return;
    const items = ring.querySelectorAll('.circle-token');
    const N = items.length;
    if (!N) return;

    const W = ring.offsetWidth  || 600;
    const H = ring.offsetHeight || 600;
    const cx = W / 2;
    const cy = H / 2;
    const rx = Math.min(cx, cy) * 0.78;
    const ry = Math.min(cx, cy) * 0.78;
    const tokenW = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--token-size')) || 80;

    items.forEach((el, i) => {
      const angle = (2 * Math.PI * i / N) - Math.PI / 2;
      const x = cx + rx * Math.cos(angle) - tokenW / 2;
      const y = cy + ry * Math.sin(angle) - tokenW / 2;
      el.style.left = `${x}px`;
      el.style.top  = `${y}px`;
    });
  }

  // Sidebar player list
  function renderPlayerList() {
    const list = document.getElementById('player-list');
    if (players.length === 0) {
      list.innerHTML = '<p style="color:var(--text-dim);font-size:0.8rem;">Cap jugador. Afegeix-ne un!</p>';
      return;
    }
    list.innerHTML = players.map((p, i) => {
      const char = p.charId ? charById(p.charId) : null;
      return `
        <div class="player-item ${p.dead ? 'dead' : ''}" onclick="openTokenModal(${i})">
          <div class="player-token-sm team-${char?.team || 'townsfolk'}">
            ${char
              ? `<img src="${imgUrl(char.id)}" alt="${char.name}" onerror="this.style.display='none'" loading="lazy"/>`
              : `<span>${i+1}</span>`}
          </div>
          <div class="player-info">
            <span class="player-name">${p.name || `Jugador ${i+1}`}</span>
            ${char ? `<span class="player-char">${char.name}</span>` : ''}
          </div>
          ${p.dead ? '<span class="dead-badge">†</span>' : ''}
        </div>
      `;
    }).join('');
  }

  // Token modal
  function openTokenModal(idx) {
    activePlayerIdx = idx;
    const p = players[idx];
    const char = p.charId ? charById(p.charId) : null;

    document.getElementById('modal-char-name').textContent =
      char ? char.name : `Jugador ${idx + 1}`;
    document.getElementById('modal-char-ability').textContent =
      char ? char.ability : '';
    document.getElementById('modal-char-team').textContent =
      char ? (TEAM_LABELS[char.team] || char.team) : '';
    document.getElementById('modal-char-team').className =
      `badge team-${char?.team || 'townsfolk'}`;
    document.getElementById('dead-label').textContent =
      p.dead ? 'Revifar' : 'Emmortallar';

    const img = document.getElementById('modal-token-img');
    img.className = `modal-token team-${char?.team || 'townsfolk'}`;
    img.innerHTML = char
      ? `<img src="${imgUrl(char.id)}" alt="${char.name}" onerror="this.style.display='none'" loading="lazy"/>`
      : `<span>${idx+1}</span>`;

    renderRemindersInModal(p);
    document.getElementById('token-modal').style.display = '';
  }

  function renderRemindersInModal(p) {
    const el = document.getElementById('reminders-display');
    if (!p.reminders || p.reminders.length === 0) {
      el.innerHTML = '';
      return;
    }
    el.innerHTML = `
      <p style="color:var(--text-muted);font-size:0.8rem;margin-bottom:0.5rem">Recordatoris:</p>
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem">
        ${p.reminders.map((r, ri) => `
          <span class="reminder-tag" onclick="removeReminder(${ri})">
            ${r} ✕
          </span>
        `).join('')}
      </div>
    `;
  }

  function closeTokenModal(e) {
    if (!e || e.target.id === 'token-modal') {
      document.getElementById('token-modal').style.display = 'none';
      activePlayerIdx = null;
    }
  }

  function toggleDead() {
    if (activePlayerIdx === null) return;
    players[activePlayerIdx].dead = !players[activePlayerIdx].dead;
    document.getElementById('dead-label').textContent =
      players[activePlayerIdx].dead ? 'Revifar' : 'Emmortallar';
    saveGameState();
    renderCircle();
  }

  function removePlayer() {
    if (activePlayerIdx === null) return;
    players.splice(activePlayerIdx, 1);
    saveGameState();
    document.getElementById('token-modal').style.display = 'none';
    activePlayerIdx = null;
    renderCircle();
  }

  function addReminderToPlayer() {
    if (activePlayerIdx === null) return;
    const char = players[activePlayerIdx].charId
      ? charById(players[activePlayerIdx].charId) : null;
    const reminders = char?.reminders || [];
    if (reminders.length === 0) {
      const custom = prompt('Recordatori personalitzat:');
      if (custom?.trim()) {
        players[activePlayerIdx].reminders.push(custom.trim());
        saveGameState();
        renderRemindersInModal(players[activePlayerIdx]);
        renderCircle();
      }
      return;
    }
    const opts = reminders.map((r, i) => `${i+1}. ${r}`).join('\n');
    const choice = prompt(`Selecciona recordatori:\n${opts}\n0. Personalitzat`);
    if (!choice) return;
    const n = parseInt(choice);
    if (n === 0) {
      const custom = prompt('Recordatori personalitzat:');
      if (custom?.trim()) players[activePlayerIdx].reminders.push(custom.trim());
    } else if (n >= 1 && n <= reminders.length) {
      players[activePlayerIdx].reminders.push(reminders[n-1]);
    }
    saveGameState();
    renderRemindersInModal(players[activePlayerIdx]);
    renderCircle();
  }

  function removeReminder(idx) {
    if (activePlayerIdx === null) return;
    players[activePlayerIdx].reminders.splice(idx, 1);
    saveGameState();
    renderRemindersInModal(players[activePlayerIdx]);
    renderCircle();
  }

  // Character picker
  function openAddTokenModal() {
    pickerMode = 'add';
    document.getElementById('picker-title').textContent = 'Afegeix Jugador';
    renderCharPicker('');
    document.getElementById('char-picker-modal').style.display = '';
    document.getElementById('char-search').value = '';
    document.getElementById('char-search').focus();
  }

  function openReplaceModal() {
    pickerMode = 'replace';
    document.getElementById('picker-title').textContent = 'Substituir Personatge';
    renderCharPicker('');
    document.getElementById('char-picker-modal').style.display = '';
    document.getElementById('char-search').value = '';
    document.getElementById('char-search').focus();
    document.getElementById('token-modal').style.display = 'none';
  }

  function closeCharPicker(e) {
    if (!e || e.target.id === 'char-picker-modal') {
      document.getElementById('char-picker-modal').style.display = 'none';
    }
  }

  function filterCharPicker(q) {
    renderCharPicker(q.toLowerCase());
  }

  function renderCharPicker(query) {
    const inUse = new Set(players.map(p => p.charId).filter(Boolean));
    const chars = selectedSetupChars.length > 0
      ? ALL_CHARS.filter(c => selectedSetupChars.includes(c.id))
      : ALL_CHARS.filter(c => ['tb','bmr','snv'].includes(c.edition));

    const filtered = chars.filter(c =>
      !query || c.name.toLowerCase().includes(query) || c.team.toLowerCase().includes(query)
    );

    const grid = document.getElementById('char-picker-grid');
    if (filtered.length === 0) {
      grid.innerHTML = '<p style="color:var(--text-muted);text-align:center;padding:2rem">Cap resultat.</p>';
      return;
    }

    grid.innerHTML = filtered.map(c => `
      <button
        class="picker-char ${inUse.has(c.id) ? 'in-use' : ''} team-${c.team}"
        onclick="pickChar('${c.id}')"
        title="${c.ability}"
      >
        <div class="picker-img team-${c.team}">
          <img src="${imgUrl(c.id)}" alt="${c.name}" onerror="this.style.display='none'" loading="lazy"/>
        </div>
        <span>${c.name}</span>
        ${inUse.has(c.id) ? '<span class="in-use-badge">·</span>' : ''}
      </button>
    `).join('');
  }

  function pickChar(charId) {
    if (pickerMode === 'add') {
      const name = prompt(`Nom del jugador ${players.length + 1} (opcional):`);
      players.push({ id: Date.now(), name: name?.trim() || `Jugador ${players.length + 1}`, charId, dead: false, reminders: [] });
    } else if (pickerMode === 'replace' && activePlayerIdx !== null) {
      players[activePlayerIdx].charId = charId;
    }
    saveGameState();
    document.getElementById('char-picker-modal').style.display = 'none';
    renderCircle();
  }

  // Bluffs
  function openBluffsModal() {
    renderBluffs('');
    document.getElementById('bluffs-modal').style.display = '';
  }

  function closeBluffs(e) {
    if (!e || e.target.id === 'bluffs-modal') {
      document.getElementById('bluffs-modal').style.display = 'none';
    }
  }

  function renderBluffs() {
    // Show active farols at top
    const activeFarolEl = document.getElementById('farol-active');
    if (bluffs.length > 0) {
      const farolChars = bluffs.map(id => charById(id)).filter(Boolean);
      activeFarolEl.innerHTML = `
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;margin-bottom:0.5rem">
          ${farolChars.map(c => `
            <div style="display:flex;flex-direction:column;align-items:center;gap:0.3rem">
              <div class="picker-img team-${c.team}" style="width:52px;height:52px">
                ${imgUrl(c.id)
                  ? `<img src="${imgUrl(c.id)}" alt="${c.name}" onerror="this.style.display='none'" loading="lazy"/>`
                  : `<span style="font-size:1rem;color:var(--text-muted)">${c.name[0]}</span>`}
              </div>
              <span style="font-size:0.7rem;color:var(--accent)">${c.name}</span>
            </div>
          `).join('')}
        </div>
      `;
    } else {
      activeFarolEl.innerHTML = '<p style="color:var(--text-dim);font-size:0.82rem;margin-bottom:0.5rem">Cap farol actiu. Randomitza des de la configuració o tria manualment.</p>';
    }

    const inUse = new Set(players.map(p => p.charId).filter(Boolean));
    const chars = selectedSetupChars.length > 0
      ? ALL_CHARS.filter(c => selectedSetupChars.includes(c.id))
      : ALL_CHARS.filter(c => ['tb','bmr','snv'].includes(c.edition) || c.id.startsWith('custom_'));

    const notInUse = chars.filter(c => !inUse.has(c.id));
    const grid = document.getElementById('bluffs-grid');
    grid.innerHTML = notInUse.map(c => `
      <button
        class="picker-char ${bluffs.includes(c.id) ? 'bluff-selected' : ''} team-${c.team}"
        onclick="toggleBluff('${c.id}', this)"
        title="${c.ability || ''}"
      >
        <div class="picker-img team-${c.team}">
          ${imgUrl(c.id)
            ? `<img src="${imgUrl(c.id)}" alt="${c.name}" onerror="this.style.display='none'" loading="lazy"/>`
            : `<span style="font-size:0.8rem;color:var(--text-muted)">${c.name[0]}</span>`}
        </div>
        <span>${c.name}</span>
        ${bluffs.includes(c.id) ? '<span class="bluff-badge">🎭</span>' : ''}
      </button>
    `).join('');
  }

  function toggleBluff(charId, btn) {
    const idx = bluffs.indexOf(charId);
    if (idx >= 0) {
      bluffs.splice(idx, 1);
      btn.classList.remove('bluff-selected');
    } else {
      bluffs.push(charId);
      btn.classList.add('bluff-selected');
    }
    saveGameState();
  }

  // Notes
  function saveNotes(val) {
    notes = val;
    saveGameState();
  }

  function clearGame() {
    if (!confirm('Segur que vols iniciar una nova partida? Es perdran les dades actuals.')) return;
    players = [];
    bluffs = [];
    notes = '';
    saveGameState();
    document.getElementById('notes-area').value = '';
    renderCircle();
  }

  // Init
  loadState();
  renderCircle();

  // Restore notes
  document.getElementById('notes-area').value = notes;

  // Reposition on resize
  window.addEventListener('resize', positionTokens);

  // Expose all onclick-referenced functions to global scope
  Object.assign(window, {
    openAddTokenModal,
    openBluffsModal,
    clearGame,
    openTokenModal,
    closeTokenModal,
    toggleDead,
    removePlayer,
    addReminderToPlayer,
    removeReminder,
    openReplaceModal,
    closeCharPicker,
    filterCharPicker,
    pickChar,
    closeBluffs,
    toggleBluff,
    saveNotes,
  });
</script>

<style>
.grimoire-page {
  display: flex;
  height: calc(100vh - 53px);
  overflow: hidden;
}

/* Sidebar */
.sidebar {
  width: 240px;
  flex-shrink: 0;
  background: var(--bg-card);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.sidebar-section {
  margin-bottom: 1.25rem;
}

.sidebar-title {
  font-size: 0.7rem;
  font-family: var(--font-sans);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-dim);
  margin-bottom: 0.5rem;
}

.sidebar-btn {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  width: 100%;
  padding: 0.45rem 0.6rem;
  border-radius: 6px;
  font-size: 0.82rem;
  color: var(--text-muted);
  background: transparent;
  border: 1px solid transparent;
  cursor: pointer;
  transition: all 0.15s;
  text-align: left;
