---
import Layout from '../layouts/Layout.astro';
import { charNamesCa } from '../data/char-names-ca';
import { charAbilitiesCa } from '../data/char-abilities-ca';
const charNamesCaJson     = JSON.stringify(charNamesCa);
const charAbilitiesCaJson = JSON.stringify(charAbilitiesCa);
---

<Layout title="Biblioteca" activePage="biblioteca">
  <div class="biblioteca-page container">

    <div class="page-header">
      <h1 class="page-title">📚 Biblioteca</h1>
      <p class="page-subtitle">Tots els personatges de Blood on the Clocktower</p>
    </div>

    <!-- Filters -->
    <div class="filters-bar">
      <div class="filter-group">
        <span class="filter-label">Edició:</span>
        <button class="filter-btn active" data-ed="all">Tots</button>
        <button class="filter-btn" data-ed="tb">🍺 Trouble Brewing</button>
        <button class="filter-btn" data-ed="bmr">🌙 Bad Moon Rising</button>
        <button class="filter-btn" data-ed="snv">🌹 Sects & Violets</button>
        <button class="filter-btn" data-ed="other">📖 Experimental</button>
        <button class="filter-btn lib-paisings-btn" data-ed="custom">🐉 Paisings</button>
      </div>
      <div class="filter-group">
        <span class="filter-label">Equip:</span>
        <button class="filter-btn active" data-team="all">Tots</button>
        <button class="filter-btn team-townsfolk" data-team="townsfolk">Vilatans</button>
        <button class="filter-btn team-outsider"  data-team="outsider">Forasters</button>
        <button class="filter-btn team-minion"    data-team="minion">Esbirros</button>
        <button class="filter-btn team-demon"     data-team="demon">Dimonis</button>
        <button class="filter-btn team-traveller" data-team="traveller">Viatgers</button>
        <button class="filter-btn team-fabled"    data-team="fabled">Llegendes</button>
      </div>
      <input type="text" id="lib-search" class="input lib-search" placeholder="🔍 Cerca per nom o poder..." />
    </div>

    <div id="lib-count" class="lib-count"></div>
    <div id="lib-grid" class="lib-grid"></div>

  </div>
</Layout>

<script id="char-names-ca-data"     type="application/json" set:html={charNamesCaJson}></script>
<script id="char-abilities-ca-data" type="application/json" set:html={charAbilitiesCaJson}></script>

<script is:inline>
(async function () {
  const CDN      = 'https://www.pocketgrimoire.co.uk';
  const WIKI_BASE = 'https://wiki.bloodontheclocktower.com/';
  const OFFICIAL_EDITIONS = ['tb', 'bmr', 'snv'];
  const HIDDEN_EDITIONS   = ['syyl', 'hdcs'];  // fan-made Chinese scripts, not shown

  const EDITION_LABELS = {
    tb:     '🍺 Trouble Brewing',
    bmr:    '🌙 Bad Moon Rising',
    snv:    '🌹 Sects & Violets',
    '':     '📖 Experimental',
    syyl:   '🀄 中文 (SYYL)',
    hdcs:   '🀄 中文 (HDCS)',
    custom: '🐉 Paisings',
  };
  const TEAM_LABELS = {
    townsfolk: 'Vilatà', outsider: 'Foraster', minion: 'Esbirro',
    demon: 'Dimoni', traveller: 'Viatger', fabled: 'Llegenda', loric: 'Lòric',
  };

  const NAMES_CA     = JSON.parse(document.getElementById('char-names-ca-data').textContent);
  const ABILITIES_CA = JSON.parse(document.getElementById('char-abilities-ca-data').textContent);

  function getNameCa(id, nameEn) { return NAMES_CA[id] ?? nameEn; }
  function getAbilityCa(id, abilityEn) { return ABILITIES_CA[id] ?? abilityEn; }

  function wikiUrl(nameEn) {
    return WIKI_BASE + nameEn.replace(/\s+/g, '_').replace(/'/g, '%27');
  }

  let ALL_CHARS = [];
  try {
    const res = await fetch('/data/characters.json');
    ALL_CHARS = await res.json();
  } catch(e) { console.error(e); }

  // Add custom chars from localStorage
  try {
    const custom = JSON.parse(localStorage.getItem('botc_custom_chars') || '[]');
    custom.forEach(c => { if (!ALL_CHARS.find(x => x.id === c.id)) ALL_CHARS.push(c); });
  } catch(_) {}

  let filterEd   = 'all';
  let filterTeam = 'all';
  let filterQ    = '';

  function imgUrl(id) {
    if (!id || id.startsWith('custom_')) return null;
    return `${CDN}/build/img/roles/${id}_g.webp`;
  }

  function editionGroup(ed) {
    if (OFFICIAL_EDITIONS.includes(ed)) return ed;
    if (ed === 'custom') return 'custom';
    return 'other'; // '', syyl, hdcs, etc.
  }

  function filtered() {
    return ALL_CHARS.filter(c => {
      if (HIDDEN_EDITIONS.includes(c.edition)) return false;
      if (filterEd !== 'all' && editionGroup(c.edition) !== filterEd) return false;
      if (filterTeam !== 'all' && c.team !== filterTeam) return false;
      if (filterQ) {
        const q = filterQ.toLowerCase();
        const nameCa     = (NAMES_CA[c.id] || '').toLowerCase();
        const abilityCa  = (ABILITIES_CA[c.id] || '').toLowerCase();
        if (
          !c.name.toLowerCase().includes(q) &&
          !nameCa.includes(q) &&
          !(c.ability||'').toLowerCase().includes(q) &&
          !abilityCa.includes(q)
        ) return false;
      }
      return true;
    });
  }

  const grid = document.getElementById('lib-grid');

  function render() {
    const chars = filtered();
    const count = document.getElementById('lib-count');

    count.textContent = `${chars.length} personatge${chars.length !== 1 ? 's' : ''}`;

    if (!chars.length) {
      grid.innerHTML = '<div class="lib-empty"><p>Cap personatge trobat.</p></div>';
      return;
    }

    grid.innerHTML = chars.map(c => {
      const url        = imgUrl(c.id);
      const edLabel    = EDITION_LABELS[c.edition] ?? c.edition;
      const teamLabel  = TEAM_LABELS[c.team] || c.team;
      const hasFirst   = c.firstNight > 0;
      const hasOther   = c.otherNight > 0;
      const isOfficial = OFFICIAL_EDITIONS.includes(c.edition);
      const isPaisings = c.edition === 'custom';
      const nameCa     = getNameCa(c.id, c.name);
      const nameEn     = c.name;
      const abilityEn  = c.ability || '';
      const abilityCa  = getAbilityCa(c.id, abilityEn);
      const initial    = nameCa[0]?.toUpperCase() || '?';

      return `
        <div class="lib-card team-${c.team}" data-char-id="${c.id}">
          <div class="lib-card-header">
            <div class="lib-token team-${c.team}">
              ${url
                ? `<img src="${url}" alt="${nameEn}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" loading="lazy"/>
                   <span class="lib-token-fallback" style="display:none">${initial}</span>`
                : `<span class="lib-token-fallback">${initial}</span>`
              }
            </div>
            <div class="lib-card-meta">
              <div class="lib-name-row">
                <h3 class="lib-char-name">${nameCa}</h3>
                ${isOfficial
                  ? `<a class="lib-wiki-link" href="${wikiUrl(nameEn)}" target="_blank" rel="noopener" title="Wiki oficial"
                      onclick="event.stopPropagation()">↗</a>`
                  : ''
                }
              </div>
              <span class="lib-name-en">${nameEn}</span>
              <div class="lib-badges" style="margin-top:.3rem">
                <span class="badge team-${c.team}">${teamLabel}</span>
                <span class="lib-ed-badge">${edLabel}</span>
                ${isPaisings ? `<span class="lib-paisings-badge">🐉 Paisings</span>` : ''}
              </div>
            </div>
          </div>
          <div class="lib-ability-row">
            <p class="lib-ability">${abilityCa ? `"${abilityCa}"` : '—'}</p>
            ${abilityEn
              ? `<button class="lib-lang-btn" data-lang="ca" title="Mostra en anglès">EN</button>`
              : ''
            }
          </div>
          ${hasFirst || hasOther ? `
            <div class="lib-night-flags">
              ${hasFirst ? `<span class="night-flag">🌑 Primera nit</span>` : ''}
              ${hasOther ? `<span class="night-flag">🌕 Altres nits</span>` : ''}
            </div>
          ` : ''}
          ${c.reminders?.length ? `
            <div class="lib-reminders">
              ${c.reminders.map(r => `<span class="lib-reminder">${r}</span>`).join('')}
            </div>
          ` : ''}
        </div>
      `;
    }).join('');
  }

  // Language toggle (event delegation on grid)
  grid.addEventListener('click', e => {
    const btn = e.target.closest('.lib-lang-btn');
    if (!btn) return;
    const card = btn.closest('.lib-card');
    const id   = card.dataset.charId;
    const char = ALL_CHARS.find(c => c.id === id);
    if (!char) return;
    const p      = card.querySelector('.lib-ability');
    const showingCa = btn.dataset.lang === 'ca';
    if (showingCa) {
      p.textContent  = char.ability ? `"${char.ability}"` : '—';
      btn.dataset.lang = 'en';
      btn.textContent  = 'CA';
      btn.title        = 'Mostra en català';
      btn.classList.add('active');
    } else {
      const abilityCa = ABILITIES_CA[id] || char.ability || '';
      p.textContent  = abilityCa ? `"${abilityCa}"` : '—';
      btn.dataset.lang = 'ca';
      btn.textContent  = 'EN';
      btn.title        = 'Mostra en anglès';
      btn.classList.remove('active');
    }
  });

  // Edition filter
  document.querySelectorAll('[data-ed]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-ed]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filterEd = btn.dataset.ed;
      render();
    });
  });

  // Team filter
  document.querySelectorAll('[data-team]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-team]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filterTeam = btn.dataset.team;
      render();
    });
  });

  // Search
  document.getElementById('lib-search').addEventListener('input', e => {
    filterQ = e.target.value;
    render();
  });

  render();
})();
</script>

<style is:global>
.biblioteca-page { padding: 0 1rem 4rem; max-width: 1400px; }

.filters-bar {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  padding: 1rem 1.25rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 1.25rem;
}

.filter-group {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.filter-label {
  font-size: 0.78rem;
  color: var(--text-dim);
  margin-right: 0.25rem;
  white-space: nowrap;
}

.filter-btn {
  padding: 0.25rem 0.65rem;
  border-radius: 99px;
  font-size: 0.78rem;
  background: var(--bg);
  border: 1px solid var(--border);
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.15s;
}
.filter-btn:hover { border-color: var(--border-accent); color: var(--text); }
.filter-btn.active { background: rgba(196,136,42,.15); border-color: var(--accent); color: var(--accent); }
.filter-btn.team-townsfolk.active { background: rgba(58,106,170,.15);  border-color: #3a6aaa; color: #3a6aaa; }
.filter-btn.team-outsider.active  { background: rgba(58,138,90,.15);   border-color: #3a8a5a; color: #3a8a5a; }
.filter-btn.team-minion.active    { background: rgba(170,58,90,.15);   border-color: #aa3a5a; color: #aa3a5a; }
.filter-btn.team-demon.active     { background: rgba(138,32,32,.2);    border-color: #8a2020; color: #c04040; }
.filter-btn.team-traveller.active { background: rgba(138,106,32,.15);  border-color: #8a6a20; color: #c4982a; }
.filter-btn.team-fabled.active    { background: rgba(106,58,170,.15);  border-color: #6a3aaa; color: #9a6ada; }
.lib-paisings-btn.active          { background: rgba(106,58,170,.15);  border-color: #6a3aaa; color: #9a6ada; }

.lib-search { max-width: 340px; }

.lib-count {
  font-size: 0.82rem;
  color: var(--text-dim);
  margin-bottom: 0.75rem;
  padding-left: 0.25rem;
}

/* Grid */
.lib-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 0.75rem;
}

.lib-empty {
  grid-column: 1/-1;
  text-align: center;
  padding: 3rem;
  color: var(--text-muted);
}

/* Card */
.lib-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-left: 3px solid var(--team-color, var(--border-accent));
  border-radius: var(--radius);
  padding: 0.875rem;
  transition: all 0.15s;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.lib-card:hover {
  border-color: var(--team-color, var(--border-accent));
  background: var(--bg-hover);
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(0,0,0,0.5);
}

.lib-card-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.lib-token {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  border: 2px solid var(--team-color, var(--border-accent));
  background: var(--team-bg, rgba(196,136,42,.1));
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lib-token img { width: 100%; height: 100%; object-fit: cover; }
.lib-token-fallback {
  font-size: 1.3rem;
  font-weight: bold;
  color: var(--team-color, var(--text-muted));
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.lib-card-meta { flex: 1; min-width: 0; }
.lib-char-name { font-size: 1rem; font-family: var(--font-serif); color: var(--text); margin-bottom: 0.3rem; }

.lib-badges { display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: center; }
.lib-ed-badge {
  font-size: 0.68rem;
  color: var(--text-muted);
  background: var(--bg);
  border: 1px solid var(--border-accent);
  border-radius: 99px;
  padding: 0.1rem 0.4rem;
}

/* Brighter team badge colors for dark background readability */
.lib-card.team-townsfolk .badge { color: #6a9be8; border-color: #6a9be8; background: rgba(58,106,170,.18); }
.lib-card.team-outsider  .badge { color: #4ab878; border-color: #4ab878; background: rgba(58,138,90,.18); }
.lib-card.team-minion    .badge { color: #e05888; border-color: #e05888; background: rgba(170,58,90,.18); }
.lib-card.team-demon     .badge { color: #e04848; border-color: #e04848; background: rgba(180,40,40,.2); }
.lib-card.team-traveller .badge { color: #d4a030; border-color: #d4a030; background: rgba(138,106,32,.18); }
.lib-card.team-fabled    .badge { color: #a870e8; border-color: #a870e8; background: rgba(106,58,170,.18); }

.lib-name-row {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  flex-wrap: wrap;
}

.lib-wiki-link {
  font-size: 0.72rem;
  color: var(--text-dim);
  text-decoration: none;
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 0.05rem 0.3rem;
  line-height: 1.4;
  flex-shrink: 0;
  transition: all 0.15s;
}
.lib-wiki-link:hover {
  color: var(--accent);
  border-color: var(--border-accent);
}

.lib-name-en {
  display: block;
  font-size: 0.72rem;
  color: var(--text-dim);
  font-style: italic;
  margin-top: 0.1rem;
}

.lib-paisings-badge {
  font-size: 0.65rem;
  padding: 0.1rem 0.4rem;
  border-radius: 99px;
  background: rgba(106,58,170,0.15);
  border: 1px solid #6a3aaa;
  color: #9a6ada;
  font-weight: 600;
  letter-spacing: 0.03em;
}

.lib-chinese-badge {
  font-size: 0.65rem;
  padding: 0.1rem 0.4rem;
  border-radius: 99px;
  background: rgba(196,80,40,0.12);
  border: 1px solid #c45028;
  color: #e07050;
  font-weight: 600;
  letter-spacing: 0.03em;
}

/* Ability row with language toggle */
.lib-ability-row {
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
}

.lib-ability {
  flex: 1;
  font-size: 0.82rem;
  color: var(--text-muted);
  line-height: 1.5;
  font-style: italic;
  margin: 0;
}

.lib-lang-btn {
  flex-shrink: 0;
  font-size: 0.62rem;
  font-weight: 700;
  padding: 0.1rem 0.35rem;
  border-radius: 4px;
  border: 1px solid var(--border);
  background: var(--bg);
  color: var(--text-dim);
  cursor: pointer;
  transition: all 0.15s;
  line-height: 1.4;
  letter-spacing: 0.04em;
  margin-top: 0.1rem;
}
.lib-lang-btn:hover { border-color: var(--border-accent); color: var(--text); }
.lib-lang-btn.active { background: rgba(196,136,42,.15); border-color: var(--accent); color: var(--accent); }

.lib-night-flags {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
}
.night-flag {
  font-size: 0.7rem;
  color: var(--text-dim);
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 0.1rem 0.4rem;
}

.lib-reminders {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
}
.lib-reminder {
  font-size: 0.68rem;
  padding: 0.15rem 0.4rem;
  background: rgba(196,136,42,.08);
  border: 1px solid var(--border-accent);
  border-radius: 4px;
  color: var(--text-dim);
}

@media (max-width: 640px) {
  .lib-grid { grid-template-columns: 1fr; }
  .lib-search { max-width: 100%; }
}
</style>
